---
import { categories } from '../lib/categories';

const searchCategories = [{ name: 'Tutte', slug: 'all' }, ...categories.map(c => ({ name: c.name, slug: c.slug }))];
---

<div class="relative" id="search-container">
  <!-- Search Trigger Button -->
  <button
    id="search-trigger"
    class="flex items-center gap-2 px-3 py-1.5 text-sm text-white/80 hover:text-white bg-white/10 hover:bg-white/20 rounded-lg transition-all duration-200"
    aria-label="Cerca articoli"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <span class="hidden sm:inline">Cerca</span>
    <kbd class="hidden md:inline-flex items-center gap-0.5 px-1.5 py-0.5 text-[10px] text-white/50 bg-white/10 rounded font-mono">
      <span class="text-[9px]">Ctrl</span>K
    </kbd>
  </button>

  <!-- Search Modal -->
  <div
    id="search-modal"
    class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden opacity-0 transition-opacity duration-200"
  >
    <div class="min-h-screen px-4 flex items-start justify-center pt-[10vh] sm:pt-[15vh]">
      <div class="bg-white w-full max-w-2xl rounded-2xl shadow-2xl scale-95 opacity-0 transition-all duration-200 overflow-hidden" id="search-content">

        <!-- Search Input -->
        <div class="flex items-center gap-3 px-5 py-4 border-b border-gray-100">
          <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="search-input"
            class="flex-1 text-base text-gray-900 border-none outline-none focus:ring-0 placeholder-gray-400 bg-transparent"
            placeholder="Cerca articoli..."
            autocomplete="off"
          />
          <div id="search-spinner" class="hidden">
            <svg class="animate-spin w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </div>
          <button
            id="close-search"
            class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Category Filter -->
        <div class="px-5 py-3 border-b border-gray-100 bg-gray-50/50">
          <div class="flex gap-1.5 overflow-x-auto no-scrollbar">
            {searchCategories.map((cat, i) => (
              <button
                class:list={[
                  "category-filter flex-shrink-0 px-3 py-1.5 rounded-lg text-xs font-medium transition-all duration-150",
                  i === 0 ? "bg-blue-600 text-white" : "text-gray-600 hover:bg-gray-200 bg-gray-100"
                ]}
                data-category={cat.name}
              >
                {cat.name}
              </button>
            ))}
          </div>
        </div>

        <!-- Results Container -->
        <div id="search-results" class="max-h-[55vh] overflow-y-auto">
          <!-- Initial state -->
          <div id="search-initial" class="py-12 px-5 text-center">
            <svg class="mx-auto w-10 h-10 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <p class="text-sm text-gray-400">Inizia a digitare per cercare</p>
          </div>

          <!-- Empty State -->
          <div id="search-empty" class="hidden py-12 px-5 text-center">
            <svg class="mx-auto w-10 h-10 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-sm font-medium text-gray-500">Nessun risultato</p>
            <p class="text-xs text-gray-400 mt-1">Prova con parole chiave diverse</p>
          </div>

          <!-- Results List -->
          <div id="search-results-list" class="divide-y divide-gray-50"></div>
        </div>

        <!-- Footer -->
        <div class="px-5 py-2.5 border-t border-gray-100 bg-gray-50/80 flex items-center justify-between text-xs text-gray-400">
          <div class="flex items-center gap-3">
            <span class="inline-flex items-center gap-1">
              <kbd class="px-1.5 py-0.5 bg-gray-200 text-gray-500 rounded font-mono text-[10px]">Esc</kbd>
              per chiudere
            </span>
          </div>
          <span id="search-count" class="hidden">
            <span id="search-count-num"></span> risultati
          </span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  let activeCategory = 'Tutte';
  let searchTimeout: ReturnType<typeof setTimeout>;

  const searchTrigger = document.getElementById('search-trigger');
  const searchModal = document.getElementById('search-modal');
  const searchContent = document.getElementById('search-content');
  const closeSearchBtn = document.getElementById('close-search');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchSpinner = document.getElementById('search-spinner');
  const searchInitial = document.getElementById('search-initial');
  const searchEmpty = document.getElementById('search-empty');
  const searchResultsList = document.getElementById('search-results-list');
  const searchCount = document.getElementById('search-count');
  const searchCountNum = document.getElementById('search-count-num');
  const categoryFilters = document.querySelectorAll('.category-filter');

  function openModal() {
    searchModal?.classList.remove('hidden');
    requestAnimationFrame(() => {
      searchModal?.classList.remove('opacity-0');
      searchContent?.classList.remove('scale-95', 'opacity-0');
    });
    document.body.classList.add('overflow-hidden');
    searchInput?.focus();
  }

  function closeModal() {
    searchModal?.classList.add('opacity-0');
    searchContent?.classList.add('scale-95', 'opacity-0');
    document.body.classList.remove('overflow-hidden');
    setTimeout(() => {
      searchModal?.classList.add('hidden');
      // Reset state
      if (searchInput) searchInput.value = '';
      if (searchResultsList) searchResultsList.innerHTML = '';
      searchInitial?.classList.remove('hidden');
      searchEmpty?.classList.add('hidden');
      searchCount?.classList.add('hidden');
    }, 200);
  }

  searchTrigger?.addEventListener('click', openModal);
  closeSearchBtn?.addEventListener('click', closeModal);
  searchModal?.addEventListener('click', (e) => {
    if (e.target === searchModal) closeModal();
  });

  // Category filter
  categoryFilters.forEach(button => {
    button.addEventListener('click', () => {
      categoryFilters.forEach(btn => {
        btn.classList.remove('bg-blue-600', 'text-white');
        btn.classList.add('text-gray-600', 'bg-gray-100');
      });
      button.classList.remove('text-gray-600', 'bg-gray-100');
      button.classList.add('bg-blue-600', 'text-white');
      activeCategory = (button as HTMLElement).dataset.category || 'Tutte';
      performSearch(searchInput?.value || '');
    });
  });

  // Search input with debounce
  searchInput?.addEventListener('input', (e) => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      performSearch((e.target as HTMLInputElement).value);
    }, 300);
  });

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
    if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
      e.preventDefault();
      openModal();
    }
  });

  function formatDate(dateStr: string): string {
    try {
      return new Date(dateStr).toLocaleDateString('it-IT', { day: 'numeric', month: 'short', year: 'numeric' });
    } catch { return ''; }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  async function performSearch(query: string) {
    if (!searchResultsList || !searchSpinner || !searchEmpty || !searchInitial) return;

    searchResultsList.innerHTML = '';
    searchCount?.classList.add('hidden');

    if (!query.trim()) {
      searchSpinner.classList.add('hidden');
      searchEmpty.classList.add('hidden');
      searchInitial.classList.remove('hidden');
      return;
    }

    searchInitial.classList.add('hidden');
    searchSpinner.classList.remove('hidden');
    searchEmpty.classList.add('hidden');

    try {
      const response = await fetch('/api/search', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          query: query.trim(),
          category: activeCategory === 'Tutte' ? undefined : activeCategory,
        }),
      });

      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();

      searchSpinner.classList.add('hidden');

      if (!data.articles?.length) {
        searchEmpty.classList.remove('hidden');
        return;
      }

      // Show count
      if (searchCount && searchCountNum) {
        searchCountNum.textContent = data.articles.length;
        searchCount.classList.remove('hidden');
      }

      searchResultsList.innerHTML = data.articles.map((article: any) => `
        <a href="/${escapeHtml(article.category_slug)}/${escapeHtml(article.slug)}"
           class="flex gap-4 px-5 py-3.5 hover:bg-blue-50/50 transition-colors group">
          ${article.image_url
            ? `<img src="${escapeHtml(article.image_url)}" alt="" class="w-16 h-16 sm:w-20 sm:h-20 object-cover rounded-lg flex-shrink-0 bg-gray-100" loading="lazy" />`
            : `<div class="w-16 h-16 sm:w-20 sm:h-20 rounded-lg flex-shrink-0 bg-gray-100 flex items-center justify-center">
                <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
               </div>`
          }
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded">${escapeHtml(article.category)}</span>
              <span class="text-xs text-gray-400">${formatDate(article.published_at)}</span>
            </div>
            <h3 class="text-sm font-semibold text-gray-900 group-hover:text-blue-700 transition-colors line-clamp-2 mb-0.5">
              ${escapeHtml(article.title)}
            </h3>
            <p class="text-xs text-gray-500 line-clamp-1">${escapeHtml(article.excerpt || '')}</p>
          </div>
          <svg class="w-4 h-4 text-gray-300 group-hover:text-blue-500 flex-shrink-0 mt-2 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      `).join('');

    } catch (error) {
      console.error('Search error:', error);
      searchSpinner.classList.add('hidden');
      searchResultsList.innerHTML = `
        <div class="py-8 text-center">
          <p class="text-sm text-red-500">Errore nella ricerca. Riprova.</p>
        </div>
      `;
    }
  }
</script>

<style>
  #search-results::-webkit-scrollbar { width: 6px; }
  #search-results::-webkit-scrollbar-track { background: transparent; }
  #search-results::-webkit-scrollbar-thumb { background: #ddd; border-radius: 3px; }
  #search-results::-webkit-scrollbar-thumb:hover { background: #bbb; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
