---
import Layout from '../../layouts/Layout.astro';
import { format, parseISO, isValid } from 'date-fns';
import { it } from 'date-fns/locale';
import { createClient } from '@supabase/supabase-js';
import { marked } from 'marked';
import { generateFAQStructuredData } from '../../lib/seo';

const { slug } = Astro.params;

// Define the Interpello type
interface Interpello {
  id: number;
  interpello_name: string;
  interpello_date: string;
  interpello_description: string;
  interpello_link: string;
  city_name: string;
  region_name: string;
  article_content?: string;
  article_title?: string;
  article_subtitle?: string;
  created_at?: string;
}

interface FAQItem {
  question: string;
  answer: string;
}

// Function to generate URL-friendly slug from interpello data
function generateInterpelloSlug(interpello: Interpello): string {
  const parts = [
    interpello.interpello_name,
    interpello.city_name,
    interpello.region_name,
    interpello.id?.toString()
  ].filter(Boolean); // Remove empty/null values
  
  return parts
    .join('-')
    .toLowerCase()
    .replace(/[^a-z0-9\-]/g, '-') // Replace non-alphanumeric chars with hyphens
    .replace(/-+/g, '-') // Replace multiple hyphens with single hyphen
    .replace(/^-|-$/g, ''); // Remove leading/trailing hyphens
}

// Initialize Supabase client
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const backendUrl = import.meta.env.BACKEND_URL || 'http://localhost:8000';

async function loadInterpelliData(): Promise<Interpello[]> {
  try {
    if (!supabaseUrl || !supabaseKey) {
      console.error('Missing Supabase environment variables');
      return [];
    }

    const supabase = createClient(supabaseUrl, supabaseKey);
    
    const { data, error } = await supabase
      .from('interpelli')
      .select('*')
      .order('interpello_date', { ascending: false });

    if (error) {
      console.error('Supabase error:', error);
      return [];
    }

    return data || [];
  } catch (error) {
    console.error('Error fetching interpelli data:', error);
    return [];
  }
}

const interpelliData: Interpello[] = await loadInterpelliData();
let interpello = interpelliData.find(i => generateInterpelloSlug(i) === slug);

function isGenericTitle(value?: string | null): boolean {
  if (!value) return true;
  const normalized = value.toLowerCase().trim();
  return normalized === 'visualizza interpelli' || normalized === 'interpelli' || normalized.length < 12;
}

async function generateArticleViaBackend(target: Interpello): Promise<{ article_title: string; article_subtitle: string; article_content: string } | null> {
  try {
    const response = await fetch(`${backendUrl}/api/interpelli/generate-article`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        interpello_name: target.interpello_name,
        interpello_date: target.interpello_date,
        interpello_description: target.interpello_description,
        interpello_link: target.interpello_link,
        city_name: target.city_name,
        region_name: target.region_name
      })
    });

    if (!response.ok) {
      console.error('Backend generation request failed:', await response.text());
      return null;
    }

    const data = await response.json();
    const article_title = String(data?.article_title || '').trim();
    const article_subtitle = String(data?.article_subtitle || '').trim();
    const article_content = String(data?.article_content || '').trim();
    if (!article_title || !article_subtitle || !article_content) return null;
    return { article_title, article_subtitle, article_content };
  } catch (error) {
    console.error('Error calling backend article generation:', error);
    return null;
  }
}

function extractFaqFromMarkdown(content?: string | null): FAQItem[] {
  if (!content) return [];

  const sectionMatch = content.match(/##\s+Domande\s+frequenti[\s\S]*$/i);
  if (!sectionMatch) return [];

  const faqSection = sectionMatch[0];
  const parts = faqSection.split(/^###\s+/m).slice(1);
  const faqs: FAQItem[] = [];

  for (const part of parts) {
    const lines = part.split('\n').map((line) => line.trim());
    const question = (lines.shift() || '').replace(/\s+/g, ' ').trim();
    const answer = lines.join('\n').trim();

    if (question && answer) {
      faqs.push({
        question: question.endsWith('?') ? question : `${question}?`,
        answer
      });
    }
  }

  return faqs;
}

function appendFaqToArticleContent(content: string, faqs: FAQItem[]): string {
  const cleanedContent = content.replace(/##\s+Domande\s+frequenti[\s\S]*$/i, '').trim();
  const faqMarkdown = [
    '## Domande frequenti',
    ...faqs.map((faq) => `### ${faq.question}\n${faq.answer}`)
  ].join('\n\n');

  return `${cleanedContent}\n\n${faqMarkdown}`.trim();
}

async function generateFaqViaBackend(target: Interpello): Promise<FAQItem[] | null> {
  try {
    const response = await fetch(`${backendUrl}/api/interpelli/generate-faq`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        interpello_name: target.interpello_name,
        interpello_date: target.interpello_date,
        interpello_description: target.interpello_description,
        interpello_link: target.interpello_link,
        city_name: target.city_name,
        region_name: target.region_name
      })
    });

    if (!response.ok) {
      console.error('Backend FAQ generation request failed:', await response.text());
      return null;
    }

    const data = await response.json();
    const items = Array.isArray(data?.faqs) ? data.faqs : [];
    const normalized = items
      .map((item: any) => ({
        question: String(item?.question || '').trim(),
        answer: String(item?.answer || '').trim()
      }))
      .filter((item: FAQItem) => item.question && item.answer)
      .slice(0, 6)
      .map((item: FAQItem) => ({
        question: item.question.endsWith('?') ? item.question : `${item.question}?`,
        answer: item.answer
      }));

    return normalized.length === 6 ? normalized : null;
  } catch (error) {
    console.error('Error calling backend FAQ generation:', error);
    return null;
  }
}

let faqItems: FAQItem[] = [];

if (interpello) {
  const shouldGenerate = isGenericTitle(interpello.article_title || interpello.interpello_name)
    || !interpello.article_subtitle?.trim()
    || !interpello.article_content?.trim();

  if (shouldGenerate && supabaseUrl && supabaseKey) {
    try {
      const generated = await generateArticleViaBackend(interpello);
      if (generated) {
        const supabase = createClient(supabaseUrl, supabaseKey);
        const { error: updateError } = await supabase
          .from('interpelli')
          .update({
            article_title: generated.article_title,
            article_subtitle: generated.article_subtitle,
            article_content: generated.article_content,
            article_generated: true
          })
          .eq('id', interpello.id);

        if (updateError) {
          console.error('Failed to persist generated interpello article:', updateError.message);
        } else {
          interpello = {
            ...interpello,
            article_title: generated.article_title,
            article_subtitle: generated.article_subtitle,
            article_content: generated.article_content
          };
        }
      }
    } catch (generationError) {
      console.error('Error generating interpello article:', generationError);
    }
  }

  faqItems = extractFaqFromMarkdown(interpello.article_content);
  const shouldGenerateFaq = faqItems.length < 6;

  if (shouldGenerateFaq && supabaseUrl && supabaseKey && interpello.article_content?.trim()) {
    try {
      const generatedFaq = await generateFaqViaBackend(interpello);

      if (generatedFaq && generatedFaq.length === 6) {
        const updatedContentWithFaq = appendFaqToArticleContent(interpello.article_content, generatedFaq);
        const supabase = createClient(supabaseUrl, supabaseKey);
        const { error: faqUpdateError } = await supabase
          .from('interpelli')
          .update({
            article_content: updatedContentWithFaq,
            article_generated: true
          })
          .eq('id', interpello.id);

        if (faqUpdateError) {
          console.error('Failed to persist generated FAQ content:', faqUpdateError.message);
        } else {
          interpello = {
            ...interpello,
            article_content: updatedContentWithFaq
          };
          faqItems = generatedFaq;
        }
      }
    } catch (faqGenerationError) {
      console.error('Error generating interpello FAQ:', faqGenerationError);
    }
  }

  if (faqItems.length === 0) {
    faqItems = extractFaqFromMarkdown(interpello.article_content);
  }
}

// Utility function to strip HTML tags and clean text for meta descriptions
const stripHtmlTags = (html: string): string => {
  if (!html) return '';
  // Remove HTML tags
  const withoutTags = html.replace(/<[^>]*>/g, '');
  // Replace multiple whitespace/newlines with single space
  const cleaned = withoutTags.replace(/\s+/g, ' ').trim();
  return cleaned;
};

// Utility function to create a safe meta description
const createSafeDescription = (text: string, maxLength: number = 160): string => {
  const cleaned = stripHtmlTags(text);
  if (cleaned.length <= maxLength) return cleaned;
  return cleaned.substring(0, maxLength - 3) + '...';
};

const slugifyHeading = (value: string): string =>
  value
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-');

const normalizeArticleHeadingsToH2 = (markdown: string): { markdown: string; headings: { id: string; title: string }[] } => {
  const lines = markdown.split('\n');
  const headings: { id: string; title: string }[] = [];
  const usedIds = new Set<string>();
  let isInFaqSection = false;

  const normalizedLines = lines.map((line) => {
    const match = line.match(/^\s{0,3}#{1,6}\s+(.+)$/);
    if (!match) return line;

    const rawTitle = match[1].trim();
    const cleanedTitle = rawTitle.replace(/\s*#+\s*$/, '').trim();
    const isFaqMainHeading = /^domande\s+frequenti$/i.test(cleanedTitle);

    if (isFaqMainHeading) {
      isInFaqSection = true;
      return `## ${cleanedTitle}`;
    }

    if (isInFaqSection) {
      return `### ${cleanedTitle}`;
    }

    let baseId = slugifyHeading(cleanedTitle) || 'sezione';
    let finalId = baseId;
    let i = 2;

    while (usedIds.has(finalId)) {
      finalId = `${baseId}-${i}`;
      i += 1;
    }

    usedIds.add(finalId);
    headings.push({ id: finalId, title: cleanedTitle });

    return `## ${cleanedTitle}`;
  });

  return { markdown: normalizedLines.join('\n'), headings };
};

const injectH2Ids = (html: string, headings: { id: string; title: string }[]): string => {
  let output = html;
  for (const heading of headings) {
    output = output.replace('<h2>', `<h2 id="${heading.id}">`);
  }
  return output;
};

// Helper function to format date (same as in interpelli.astro for consistency)
const formatDate = (dateString: string): string => {
  try {
    const parsedDate = parseISO(dateString);
    if (!isValid(parsedDate)) return "Data non valida";
    return format(parsedDate, 'dd MMMM yyyy', { locale: it });
  } catch (e) {
    return "Data non valida";
  }
};

const normalizedArticle = interpello?.article_content
  ? normalizeArticleHeadingsToH2(interpello.article_content)
  : null;

// Convert markdown to HTML if article_content exists
const articleHtml = normalizedArticle
  ? injectH2Ids(marked(normalizedArticle.markdown), normalizedArticle.headings)
  : null;

const articleToc = normalizedArticle?.headings || [];

// Define keywords - combining relevant fields
const keywords = [
  interpello?.interpello_name,
  interpello?.region_name,
  interpello?.city_name,
  interpello?.interpello_description,
  'interpello',
  'scuola',
  'supplenza',
  'insegnanti',
  'MAD'
]
.filter(kw => kw) // Remove null/undefined/empty strings
.map(kw => stripHtmlTags(kw!).toLowerCase()) // Clean HTML and convert to lowercase
.join(', ');

const pageTitle = interpello 
  ? (interpello.article_title || `${interpello.interpello_name} - Interpello Scuola - EduNews24`)
  : 'Interpello non Trovato - EduNews24';

const pageDescription = interpello?.article_subtitle 
  ? createSafeDescription(interpello.article_subtitle, 160)
  : interpello?.interpello_description 
    ? createSafeDescription(interpello.interpello_description, 160)
    : 'Dettagli dell\'interpello scolastico.';

const canonicalInterpelloUrl = interpello
  ? (Astro.url?.href || `https://edunews24.it/interpelli/${slug}`)
  : null;

// Generate structured data for the interpello
const structuredData = interpello ? JSON.stringify(
  Object.fromEntries(
    Object.entries({
      "@context": "https://schema.org",
      "@type": "JobPosting",
      title: interpello.article_title || interpello.interpello_name,
      description: interpello.article_subtitle || interpello.interpello_description,
      datePosted: interpello.interpello_date?.split('T')[0],
      identifier: slug,
      sameAs: interpello.interpello_link,
      url: canonicalInterpelloUrl,
      employmentType: "Supplenza",
      hiringOrganization: {
        "@type": "Organization",
        name: interpello.interpello_name || "Scuola Italiana"
      },
      jobLocation: {
        "@type": "Place",
        address: {
          "@type": "PostalAddress",
          addressLocality: interpello.city_name,
          addressRegion: interpello.region_name,
          addressCountry: "IT"
        }
      }
    }).filter(([_, value]) => value !== undefined && value !== null && value !== '')
  )
) : '';

const breadcrumbStructuredData = interpello ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "item": {
        "@type": "Thing",
        "id": "https://edunews24.it/",
        "name": "Home"
      }
    },
    {
      "@type": "ListItem",
      "position": 2,
      "item": {
        "@type": "Thing",
        "id": "https://edunews24.it/interpelli",
        "name": "Interpelli"
      }
    },
    {
      "@type": "ListItem",
      "position": 3,
      "item": {
        "@type": "WebPage",
        "id": canonicalInterpelloUrl,
        "name": interpello.article_title || interpello.interpello_name || 'Dettaglio interpello'
      }
    }
  ]
}) : null;

const faqStructuredData = faqItems.length > 0 ? generateFAQStructuredData(faqItems.slice(0, 6)) : null;
---

<Layout title={pageTitle} description={pageDescription} keywords={keywords}>
  {interpello && <script type="application/ld+json" set:html={structuredData} slot="head" />}
  {breadcrumbStructuredData && <script type="application/ld+json" set:html={breadcrumbStructuredData} slot="head" />}
  {faqStructuredData && <script type="application/ld+json" set:html={faqStructuredData} slot="head" />}
  
  <main class="bg-gray-50 py-12">
    <div class="container mx-auto px-4 max-w-4xl">
      {interpello ? (
        <article class="bg-white rounded-lg shadow-md overflow-hidden p-6 md:p-8">
          {/* Header Section */}
          <div class="border-b pb-5 mb-6">
            <h1 class="text-2xl md:text-3xl font-bold text-primary mb-2">
              {interpello.article_title || interpello.interpello_name}
            </h1>
            {interpello.article_subtitle && (
              <p class="text-lg text-gray-600 italic mb-3">{interpello.article_subtitle}</p>
            )}
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-3">
              <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-500">
                {interpello.interpello_name && (
                  <span class="inline-flex items-center px-2 py-1 bg-purple-100 text-purple-800 rounded-md text-xs font-medium">
                    🏫 {interpello.interpello_name}
                  </span>
                )}
                {interpello.region_name && (
                  <span class="inline-flex items-center px-2 py-1 bg-blue-100 text-blue-800 rounded-md text-xs font-medium">
                    📍 {interpello.region_name}
                  </span>
                )}
                {interpello.city_name && (
                  <span class="inline-flex items-center px-2 py-1 bg-green-100 text-green-800 rounded-md text-xs font-medium">
                    🏙️ {interpello.city_name}
                  </span>
                )}
              </div>
              {interpello.interpello_link && (
                <a
                  href={interpello.interpello_link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center px-4 py-2 border border-primary text-sm font-medium rounded text-primary bg-white hover:bg-primary/10 focus:outline-none focus:ring-2 focus:ring-offset-1 focus:ring-primary transition"
                >
                  Vai all'Interpello Ufficiale
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
            </div>
            <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500">
              {interpello.interpello_date && (
                <span>Pubblicato il: <span class="font-medium text-gray-700">{formatDate(interpello.interpello_date)}</span></span>
              )}
            </div>
          </div>

          {/* Details Grid - Original Info */}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4 mb-6 text-sm bg-gray-50 p-4 rounded-md">
            {interpello.interpello_description && (
              <div class="md:col-span-2"><strong class="block text-gray-500 text-xs uppercase">Descrizione</strong><p>{interpello.interpello_description}</p></div>
            )}
          </div>

          {articleToc.length > 0 && (
            <nav class="mb-6 border border-gray-200 rounded-md bg-white p-4" aria-label="Indice articolo">
              <h2 class="text-base font-semibold text-gray-800 mb-3">Indice</h2>
              <ul class="space-y-1 text-sm">
                {articleToc.map((item) => (
                  <li>
                    <a href={`#${item.id}`} class="text-primary hover:underline">{item.title}</a>
                  </li>
                ))}
              </ul>
            </nav>
          )}

          {/* Article Content Section - Main Content */}
          {articleHtml ? (
            <div class="prose prose-sm lg:prose-base max-w-none text-gray-700 border-t pt-6">
              <div set:html={articleHtml} />
            </div>
          ) : (
            <div class="border-t pt-6">
              <p class="text-gray-600">L'articolo dettagliato per questo interpello sarà disponibile a breve.</p>
            </div>
          )}

          <div class="mt-8 pt-6 border-t border-gray-200 text-center">
            <a href="/interpelli" class="text-sm text-gray-600 hover:text-primary transition">
              ← Torna alla lista degli interpelli
            </a>
          </div>

        </article>
      ) : (
        <div class="text-center py-20">
          <h1 class="text-2xl font-semibold text-gray-700 mb-4">Interpello non Trovato</h1>
          <p class="text-gray-500 mb-6">L'interpello che stai cercando non è disponibile o lo slug non è corretto.</p>
          <a href="/interpelli" class="text-primary hover:underline">Torna alla lista degli interpelli</a>
        </div>
      )}
    </div>
  </main>
</Layout>

<style is:global>
/* Prose styles for the article content */
.prose :where(p):not(:where([class~="not-prose"] *)) {
  margin-top: 1em;
  margin-bottom: 1em;
}

.prose :where(h1):not(:where([class~="not-prose"] *)) {
  font-size: 2em;
  font-weight: 700;
  margin-top: 0.8em;
  margin-bottom: 0.4em;
  color: #1a202c;
  line-height: 1.2;
}

.prose :where(h2):not(:where([class~="not-prose"] *)) {
  font-size: 1.5em;
  font-weight: 600;
  margin-top: 1.2em;
  margin-bottom: 0.5em;
  color: #2d3748;
  line-height: 1.3;
}

.prose :where(h3):not(:where([class~="not-prose"] *)) {
  font-size: 1.25em;
  font-weight: 600;
  margin-top: 1em;
  margin-bottom: 0.4em;
  color: #2d3748;
}

.prose a {
  color: #0056b3;
  text-decoration: underline;
}

.prose a:hover {
  color: #003d80;
}

.prose strong {
  font-weight: 600;
  color: #333;
}

.prose em {
  font-style: italic;
  color: #4a5568;
}

.prose ul, .prose ol {
  margin-top: 1em;
  margin-bottom: 1em;
  padding-left: 1.5em;
}

.prose li {
  margin-top: 0.3em;
  margin-bottom: 0.3em;
}

.prose blockquote {
  border-left: 4px solid #cbd5e0;
  padding-left: 1em;
  margin: 1.5em 0;
  font-style: italic;
  color: #4a5568;
}

.prose code {
  background-color: #f7fafc;
  padding: 0.2em 0.4em;
  border-radius: 3px;
  font-size: 0.9em;
  font-family: 'Courier New', monospace;
}

.prose pre {
  background-color: #2d3748;
  color: #e2e8f0;
  padding: 1em;
  border-radius: 5px;
  overflow-x: auto;
  margin: 1.5em 0;
}

.prose pre code {
  background-color: transparent;
  padding: 0;
  color: inherit;
}
</style>
