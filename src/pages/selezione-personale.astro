---
import Layout from '../layouts/Layout.astro';
import { format, parseISO, isValid, differenceInCalendarDays } from 'date-fns';
import { it } from 'date-fns/locale';
import { createClient } from '@supabase/supabase-js';
import type { SelezioneBando } from '../types/bandi';

// Initialize Supabase client
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const PAGE_SIZE = 20;

// Function to fetch bandi data from Supabase
async function loadBandiData(): Promise<{ items: SelezioneBando[], total: number }> {
  try {
    if (!supabaseUrl || !supabaseKey) {
      console.error('Missing Supabase environment variables');
      return { items: [], total: 0 };
    }

    const supabase = createClient(supabaseUrl, supabaseKey);

    const { count } = await supabase
      .from('selezione_personale')
      .select('*', { count: 'exact', head: true })
      .eq('status', 'completed');

    const { data, error } = await supabase
      .from('selezione_personale')
      .select('*')
      .eq('status', 'completed')
      .order('data_pubblicazione', { ascending: false })
      .range(0, PAGE_SIZE - 1);

    if (error) {
      console.error('Supabase error:', error);
      return { items: [], total: 0 };
    }

    return { items: (data || []) as SelezioneBando[], total: count || 0 };
  } catch (error) {
    console.error('Error fetching bandi data:', error);
    return { items: [], total: 0 };
  }
}

// Load filter options
async function loadFilterOptions() {
  try {
    if (!supabaseUrl || !supabaseKey) return { categorie: [], settori: [], sedi: [] };
    const supabase = createClient(supabaseUrl, supabaseKey);
    const { data } = await supabase
      .from('selezione_personale')
      .select('categorie, settori, sedi')
      .eq('status', 'completed');

    const categorie = new Set<string>();
    const settori = new Set<string>();
    const sedi = new Set<string>();

    (data || []).forEach((row: any) => {
      (row.categorie || []).forEach((c: string) => categorie.add(c));
      (row.settori || []).forEach((s: string) => settori.add(s));
      (row.sedi || []).forEach((s: string) => sedi.add(s));
    });

    return {
      categorie: [...categorie].sort(),
      settori: [...settori].sort(),
      sedi: [...sedi].sort(),
    };
  } catch {
    return { categorie: [], settori: [], sedi: [] };
  }
}

const { items: bandiData, total: totalCount } = await loadBandiData();
const totalPages = Math.ceil(totalCount / PAGE_SIZE);
const filterOptions = await loadFilterOptions();

const formatDate = (dateString: string): string => {
  try {
    const parsedDate = parseISO(dateString);
    if (!isValid(parsedDate)) return "Data non valida";
    return format(parsedDate, 'dd MMM yyyy', { locale: it });
  } catch {
    return "Data non valida";
  }
};

const getDaysRemaining = (dateString: string): number | null => {
  try {
    const parsedDate = parseISO(dateString);
    if (!isValid(parsedDate)) return null;
    return differenceInCalendarDays(parsedDate, new Date());
  } catch {
    return null;
  }
};

// Precompute card data
const bandiWithDays = bandiData.map((bando: SelezioneBando) => {
  const daysLeft = bando.data_scadenza ? getDaysRemaining(bando.data_scadenza) : null;
  return {
    ...bando,
    daysLeft,
    isExpiring: daysLeft !== null && daysLeft >= 0 && daysLeft <= 7,
    isExpired: daysLeft !== null && daysLeft < 0,
  };
});

const pageTitle = "Selezione Personale - EduNews24";
const pageDescription = "Con EduNews24.it ricerca degli annunci di lavoro della pubblica amministrazione e delle migliori aziende private";
const pageKeywords = "selezione personale, lavoro, ricerca lavoro, offerte lavoro, annunci lavoro, pubblica amministrazione, bandi pubblici, bandi e concorsi";
---
<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
>
  <main class="bg-gray-50 min-h-screen">
    {/* Hero header */}
    <div class="bg-gradient-to-r from-blue-700 to-indigo-800 text-white py-10 px-4 sm:px-6 lg:px-8">
      <div class="container mx-auto max-w-6xl">
        <nav class="flex text-sm text-blue-200 mb-4" aria-label="Breadcrumb">
          <ol class="inline-flex items-center space-x-1">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li class="flex items-center">
              <svg class="w-4 h-4 mx-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
              <span class="text-white font-medium">Selezione Personale</span>
            </li>
          </ol>
        </nav>
        <h1 class="text-3xl md:text-4xl font-bold mb-2">Selezione Personale</h1>
        <p class="text-blue-100 text-lg max-w-2xl">Bandi, concorsi pubblici e opportunita di lavoro nella Pubblica Amministrazione italiana.</p>
        <div class="mt-4 flex items-center gap-4 text-sm">
          <span class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm px-3 py-1.5 rounded-full">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            <span id="hero-count">{totalCount}</span> bandi disponibili
          </span>
        </div>
      </div>
    </div>

    <div class="container mx-auto px-4 max-w-6xl -mt-6">
      {/* Filter Controls */}
      <div class="mb-6 p-5 bg-white rounded-xl shadow-md border border-gray-100">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-3 items-end">
          {/* Search */}
          <div class="lg:col-span-2">
            <label for="search-filter" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Cerca</label>
            <div class="relative">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
              <input type="text" id="search-filter" placeholder="Titolo, Ente, Codice..." class="w-full pl-10 pr-3 py-2.5 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm bg-gray-50 transition-colors">
            </div>
          </div>

          {/* Categoria */}
          <div>
            <label for="category-filter" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Categoria</label>
            <select id="category-filter" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm bg-gray-50">
              <option value="">Tutte</option>
              {filterOptions.categorie.map(cat => <option value={cat}>{cat}</option>)}
            </select>
          </div>

          {/* Settore */}
          <div>
            <label for="settore-filter" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Settore</label>
            <select id="settore-filter" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm bg-gray-50">
              <option value="">Tutti</option>
              {filterOptions.settori.map(s => <option value={s}>{s}</option>)}
            </select>
          </div>

          {/* Sede */}
          <div>
            <label for="sede-filter" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Sede</label>
            <select id="sede-filter" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm bg-gray-50">
              <option value="">Tutte</option>
              {filterOptions.sedi.map(s => <option value={s}>{s}</option>)}
            </select>
          </div>

          {/* Reset Button */}
          <div>
            <label class="block text-xs font-semibold text-transparent mb-1.5">Reset</label>
            <button id="reset-filters" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm font-medium text-gray-600 bg-gray-50 hover:bg-gray-100 transition-colors flex items-center justify-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
              Resetta
            </button>
          </div>
        </div>
      </div>

      {/* Results Count */}
      <div class="mb-4 flex items-center justify-between">
        <p id="results-count" class="text-sm text-gray-500">
          <span id="visible-count" class="font-semibold text-gray-700">{totalCount}</span> bandi trovati
        </p>
        <div id="loading-indicator" class="hidden items-center gap-2 text-sm text-blue-600">
          <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
          Caricamento...
        </div>
      </div>

      <div id="bandi-list" class="space-y-4">
        {bandiData.length === 0 ? (
          <div id="no-results-message" class="text-center py-16 bg-white rounded-xl shadow-sm">
            <svg class="mx-auto w-16 h-16 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            <p class="text-gray-500 text-lg font-medium">Nessun bando trovato</p>
            <p class="text-gray-400 text-sm mt-1">Prova a modificare i filtri di ricerca</p>
          </div>
        ) : (
          <Fragment>
            {bandiWithDays.map((bando) => (
                <article class="bando-item group bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md hover:border-gray-200 transition-all duration-200">
                  <a href={`/selezione-personale/${bando.slug}`} class="block">
                    <div class="p-5 sm:p-6">
                      <div class="flex flex-col sm:flex-row justify-between sm:items-start gap-2 mb-3">
                        <div class="flex-1 min-w-0">
                          <h2 class="text-base sm:text-lg font-bold text-gray-900 group-hover:text-blue-700 transition-colors line-clamp-2">
                            {bando.article_title || bando.titolo}
                          </h2>
                        </div>
                        <div class="flex items-center gap-2 flex-shrink-0">
                          {bando.daysLeft !== null && !bando.isExpired && (
                            <span class:list={[
                              "text-xs font-medium px-2 py-1 rounded-md",
                              bando.isExpiring ? "bg-amber-50 text-amber-700 border border-amber-200" : "bg-blue-50 text-blue-600 border border-blue-100"
                            ]}>
                              {bando.daysLeft === 0 ? "Scade oggi" : `${bando.daysLeft}g rimasti`}
                            </span>
                          )}
                          <span class:list={[
                            "inline-flex items-center gap-1 px-2.5 py-1 text-xs font-semibold rounded-md",
                            bando.calculated_status === 'OPEN' ? "bg-emerald-50 text-emerald-700 border border-emerald-200" :
                            bando.calculated_status === 'CLOSED' ? "bg-red-50 text-red-700 border border-red-200" :
                            "bg-yellow-50 text-yellow-700 border border-yellow-200"
                          ]}>
                            <span class:list={[
                              "w-1.5 h-1.5 rounded-full",
                              bando.calculated_status === 'OPEN' ? "bg-emerald-500" :
                              bando.calculated_status === 'CLOSED' ? "bg-red-500" : "bg-yellow-500"
                            ]}></span>
                            {bando.status_label}
                          </span>
                        </div>
                      </div>

                      {(bando.enti_riferimento?.length > 0 || bando.sedi?.length > 0) && (
                        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-500 mb-3">
                          {bando.enti_riferimento?.length > 0 && (
                            <span class="inline-flex items-center gap-1.5">
                              <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                              <span class="truncate">{bando.enti_riferimento.join(', ')}</span>
                            </span>
                          )}
                          {bando.sedi?.length > 0 && (
                            <span class="inline-flex items-center gap-1.5">
                              <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                              <span class="truncate">{bando.sedi.join(', ')}</span>
                            </span>
                          )}
                        </div>
                      )}

                      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-gray-600 py-3 border-t border-gray-50">
                        {bando.figura_ricercata && (
                          <span class="inline-flex items-center gap-1.5">
                            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            <span class="font-medium">{bando.figura_ricercata}</span>
                          </span>
                        )}
                        {bando.num_posti && (
                          <span class="inline-flex items-center gap-1.5">
                            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            <span><strong>{bando.num_posti}</strong> {bando.num_posti === 1 ? 'posto' : 'posti'}</span>
                          </span>
                        )}
                        {bando.tipo_procedura && (
                          <span class="inline-flex items-center gap-1.5">
                            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                            {bando.tipo_procedura}
                          </span>
                        )}
                        {bando.data_pubblicazione && (
                          <span class="inline-flex items-center gap-1.5">
                            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            {formatDate(bando.data_pubblicazione)}
                          </span>
                        )}
                        {bando.data_scadenza && (
                          <span class:list={["inline-flex items-center gap-1.5", bando.isExpiring ? "text-amber-600 font-medium" : bando.isExpired ? "text-red-500" : ""]}>
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            Scadenza: {formatDate(bando.data_scadenza)}
                          </span>
                        )}
                        <span class="inline-flex items-center gap-1 text-xs text-gray-400">
                          Cod. {bando.codice}
                        </span>
                      </div>

                      {(bando.categorie?.length > 0 || bando.settori?.length > 0) && (
                        <div class="flex flex-wrap gap-1.5 mt-3">
                          {bando.categorie?.map((cat: string) => (
                            <span class="inline-block bg-gray-100 text-gray-600 text-xs font-medium px-2 py-0.5 rounded-md">{cat}</span>
                          ))}
                          {bando.settori?.map((sec: string) => (
                            <span class="inline-block bg-blue-50 text-blue-600 text-xs font-medium px-2 py-0.5 rounded-md">{sec}</span>
                          ))}
                        </div>
                      )}

                      {bando.article_subtitle && (
                        <p class="text-gray-500 text-sm leading-relaxed mt-3 line-clamp-2">{bando.article_subtitle}</p>
                      )}
                    </div>
                  </a>
                </article>
            ))}
            <p id="no-filtered-results-message" class="text-center text-gray-500 text-lg py-10 hidden">Nessun bando corrisponde ai filtri selezionati.</p>
          </Fragment>
        )}
      </div>

      {/* Pagination */}
      {totalPages > 1 && (
        <nav id="pagination" class="mt-8 mb-12 flex justify-center items-center gap-3" data-total-pages={totalPages} data-page-size={PAGE_SIZE}>
          <button id="prev-page" class="inline-flex items-center gap-1.5 px-4 py-2.5 border border-gray-200 rounded-lg text-sm font-medium text-gray-600 bg-white hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors shadow-sm" disabled>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            Precedente
          </button>
          <span class="px-4 py-2 text-sm text-gray-500 bg-white border border-gray-200 rounded-lg shadow-sm">
            <span id="current-page-num" class="font-semibold text-gray-700">1</span> / <span id="total-pages-num">{totalPages}</span>
          </span>
          <button id="next-page" class="inline-flex items-center gap-1.5 px-4 py-2.5 border border-gray-200 rounded-lg text-sm font-medium text-gray-600 bg-white hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors shadow-sm">
            Successiva
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </button>
        </nav>
      )}
    </div>
  </main>
</Layout>

<script is:inline define:vars={{ supabaseUrl, supabaseKey, PAGE_SIZE }}>
  async function supabaseFetch(table, params) {
    const url = new URL(`${supabaseUrl}/rest/v1/${table}`);
    Object.entries(params).forEach(([k, v]) => url.searchParams.set(k, v));
    const res = await fetch(url.toString(), {
      headers: {
        'apikey': supabaseKey,
        'Authorization': `Bearer ${supabaseKey}`,
        'Prefer': 'count=exact',
      },
    });
    const total = parseInt(res.headers.get('content-range')?.split('/')[1] || '0', 10);
    const data = await res.json();
    return { data, total };
  }

  const searchInput = document.getElementById('search-filter');
  const categorySelect = document.getElementById('category-filter');
  const settoreSelect = document.getElementById('settore-filter');
  const sedeSelect = document.getElementById('sede-filter');
  const bandiList = document.getElementById('bandi-list');
  const noFilteredResultsMessage = document.getElementById('no-filtered-results-message');
  const resetButton = document.getElementById('reset-filters');
  const visibleCountSpan = document.getElementById('visible-count');
  const heroCountSpan = document.getElementById('hero-count');
  const loadingIndicator = document.getElementById('loading-indicator');
  const prevBtn = document.getElementById('prev-page');
  const nextBtn = document.getElementById('next-page');
  const currentPageNum = document.getElementById('current-page-num');
  const totalPagesNum = document.getElementById('total-pages-num');

  let currentPage = 1;
  let isLoading = false;

  function formatDateDisplay(dateString) {
    try {
      const d = new Date(dateString);
      if (isNaN(d.getTime())) return 'N/D';
      return d.toLocaleDateString('it-IT', { day: '2-digit', month: 'short', year: 'numeric' });
    } catch { return 'N/D'; }
  }

  function getDaysLeft(dateString) {
    try {
      const d = new Date(dateString);
      if (isNaN(d.getTime())) return null;
      const now = new Date();
      now.setHours(0,0,0,0);
      d.setHours(0,0,0,0);
      return Math.ceil((d - now) / (1000 * 60 * 60 * 24));
    } catch { return null; }
  }

  function renderItems(items) {
    const existingItems = bandiList.querySelectorAll('.bando-item');
    existingItems.forEach(el => el.remove());

    if (items.length === 0) {
      if (noFilteredResultsMessage) noFilteredResultsMessage.classList.remove('hidden');
      return;
    }
    if (noFilteredResultsMessage) noFilteredResultsMessage.classList.add('hidden');

    const fragment = document.createDocumentFragment();
    items.forEach(item => {
      const daysLeft = item.data_scadenza ? getDaysLeft(item.data_scadenza) : null;
      const isExpiring = daysLeft !== null && daysLeft >= 0 && daysLeft <= 7;
      const isExpired = daysLeft !== null && daysLeft < 0;

      const statusDot = item.calculated_status === 'OPEN' ? 'bg-emerald-500' :
                         item.calculated_status === 'CLOSED' ? 'bg-red-500' : 'bg-yellow-500';
      const statusBg = item.calculated_status === 'OPEN' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' :
                        item.calculated_status === 'CLOSED' ? 'bg-red-50 text-red-700 border-red-200' :
                        'bg-yellow-50 text-yellow-700 border-yellow-200';

      const article = document.createElement('article');
      article.className = 'bando-item group bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md hover:border-gray-200 transition-all duration-200';

      const enti = (item.enti_riferimento || []).join(', ');
      const sedi = (item.sedi || []).join(', ');
      const categorie = (item.categorie || []).map(c => `<span class="inline-block bg-gray-100 text-gray-600 text-xs font-medium px-2 py-0.5 rounded-md">${c}</span>`).join('');
      const settori = (item.settori || []).map(s => `<span class="inline-block bg-blue-50 text-blue-600 text-xs font-medium px-2 py-0.5 rounded-md">${s}</span>`).join('');

      let daysLeftHtml = '';
      if (daysLeft !== null && !isExpired) {
        const cls = isExpiring ? 'bg-amber-50 text-amber-700 border border-amber-200' : 'bg-blue-50 text-blue-600 border border-blue-100';
        const label = daysLeft === 0 ? 'Scade oggi' : `${daysLeft}g rimasti`;
        daysLeftHtml = `<span class="text-xs font-medium px-2 py-1 rounded-md ${cls}">${label}</span>`;
      }

      const scadenzaCls = isExpiring ? 'text-amber-600 font-medium' : isExpired ? 'text-red-500' : '';

      article.innerHTML = `
        <a href="/selezione-personale/${item.slug}" class="block">
          <div class="p-5 sm:p-6">
            <div class="flex flex-col sm:flex-row justify-between sm:items-start gap-2 mb-3">
              <div class="flex-1 min-w-0">
                <h2 class="text-base sm:text-lg font-bold text-gray-900 group-hover:text-blue-700 transition-colors line-clamp-2">${item.article_title || item.titolo || ''}</h2>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                ${daysLeftHtml}
                <span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-semibold rounded-md border ${statusBg}">
                  <span class="w-1.5 h-1.5 rounded-full ${statusDot}"></span>
                  ${item.status_label || ''}
                </span>
              </div>
            </div>
            ${(enti || sedi) ? `<div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-500 mb-3">
              ${enti ? `<span class="inline-flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg><span class="truncate">${enti}</span></span>` : ''}
              ${sedi ? `<span class="inline-flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg><span class="truncate">${sedi}</span></span>` : ''}
            </div>` : ''}
            <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-gray-600 py-3 border-t border-gray-50">
              ${item.figura_ricercata ? `<span class="inline-flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg><span class="font-medium">${item.figura_ricercata}</span></span>` : ''}
              ${item.num_posti ? `<span class="inline-flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg><span><strong>${item.num_posti}</strong> ${item.num_posti === 1 ? 'posto' : 'posti'}</span></span>` : ''}
              ${item.tipo_procedura ? `<span class="inline-flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>${item.tipo_procedura}</span>` : ''}
              ${item.data_pubblicazione ? `<span class="inline-flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>${formatDateDisplay(item.data_pubblicazione)}</span>` : ''}
              ${item.data_scadenza ? `<span class="inline-flex items-center gap-1.5 ${scadenzaCls}"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>Scadenza: ${formatDateDisplay(item.data_scadenza)}</span>` : ''}
              <span class="inline-flex items-center gap-1 text-xs text-gray-400">Cod. ${item.codice || ''}</span>
            </div>
            ${(categorie || settori) ? `<div class="flex flex-wrap gap-1.5 mt-3">${categorie}${settori}</div>` : ''}
            ${item.article_subtitle ? `<p class="text-gray-500 text-sm leading-relaxed mt-3 line-clamp-2">${item.article_subtitle}</p>` : ''}
          </div>
        </a>`;
      fragment.appendChild(article);
    });

    if (noFilteredResultsMessage) {
      bandiList.insertBefore(fragment, noFilteredResultsMessage);
    } else {
      bandiList.appendChild(fragment);
    }
  }

  function updatePagination(total) {
    const pages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (currentPageNum) currentPageNum.textContent = currentPage;
    if (totalPagesNum) totalPagesNum.textContent = pages;
    if (prevBtn) prevBtn.disabled = currentPage <= 1;
    if (nextBtn) nextBtn.disabled = currentPage >= pages;
    const paginationNav = document.getElementById('pagination');
    if (paginationNav) paginationNav.style.display = pages <= 1 ? 'none' : 'flex';
  }

  async function loadPage() {
    if (isLoading) return;
    isLoading = true;
    if (loadingIndicator) loadingIndicator.classList.remove('hidden');
    if (loadingIndicator) loadingIndicator.classList.add('flex');

    const searchTerm = searchInput?.value?.trim() || '';
    const category = categorySelect?.value || '';
    const settore = settoreSelect?.value || '';
    const sede = sedeSelect?.value || '';

    const from = (currentPage - 1) * PAGE_SIZE;

    const params = {
      'select': '*',
      'status': 'eq.completed',
      'order': 'data_pubblicazione.desc',
      'offset': from.toString(),
      'limit': PAGE_SIZE.toString(),
    };

    if (searchTerm) {
      params['or'] = `(article_title.ilike.*${searchTerm}*,titolo.ilike.*${searchTerm}*,codice.ilike.*${searchTerm}*)`;
    }
    if (category) {
      params['categorie'] = `cs.{${category}}`;
    }
    if (settore) {
      params['settori'] = `cs.{${settore}}`;
    }
    if (sede) {
      params['sedi'] = `cs.{${sede}}`;
    }

    try {
      const { data, total } = await supabaseFetch('selezione_personale', params);
      renderItems(data || []);
      if (visibleCountSpan) visibleCountSpan.textContent = total;
      if (heroCountSpan) heroCountSpan.textContent = total;
      updatePagination(total);
    } catch (e) {
      console.error('Errore caricamento bandi:', e);
    } finally {
      isLoading = false;
      if (loadingIndicator) loadingIndicator.classList.add('hidden');
      if (loadingIndicator) loadingIndicator.classList.remove('flex');
    }
  }

  function resetAndLoad() {
    currentPage = 1;
    loadPage();
  }

  function debounce(func, wait) {
    let timeout;
    return (...args) => {
      clearTimeout(timeout);
      timeout = setTimeout(() => func(...args), wait);
    };
  }

  const debouncedLoad = debounce(resetAndLoad, 300);

  if (searchInput) searchInput.addEventListener('input', debouncedLoad);
  if (categorySelect) categorySelect.addEventListener('change', resetAndLoad);
  if (settoreSelect) settoreSelect.addEventListener('change', resetAndLoad);
  if (sedeSelect) sedeSelect.addEventListener('change', resetAndLoad);

  if (prevBtn) prevBtn.addEventListener('click', () => {
    if (currentPage > 1) { currentPage--; loadPage(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
  });
  if (nextBtn) nextBtn.addEventListener('click', () => {
    currentPage++;
    loadPage();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  if (resetButton) {
    resetButton.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      if (categorySelect) categorySelect.value = '';
      if (settoreSelect) settoreSelect.value = '';
      if (sedeSelect) sedeSelect.value = '';
      resetAndLoad();
    });
  }
</script>
