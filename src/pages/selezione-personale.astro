---
import Layout from '../layouts/Layout.astro';
import { format, parseISO, isValid } from 'date-fns';
import { it } from 'date-fns/locale';
import { createClient } from '@supabase/supabase-js';
import type { SelezioneBando } from '../types/bandi';

// Initialize Supabase client
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const PAGE_SIZE = 20;

// Function to fetch bandi data from Supabase
async function loadBandiData(): Promise<{ items: SelezioneBando[], total: number }> {
  try {
    if (!supabaseUrl || !supabaseKey) {
      console.error('Missing Supabase environment variables');
      return { items: [], total: 0 };
    }

    const supabase = createClient(supabaseUrl, supabaseKey);

    const { count } = await supabase
      .from('selezione_personale')
      .select('*', { count: 'exact', head: true })
      .eq('status', 'completed');

    const { data, error } = await supabase
      .from('selezione_personale')
      .select('*')
      .eq('status', 'completed')
      .order('data_pubblicazione', { ascending: false })
      .range(0, PAGE_SIZE - 1);

    if (error) {
      console.error('Supabase error:', error);
      return { items: [], total: 0 };
    }

    return { items: (data || []) as SelezioneBando[], total: count || 0 };
  } catch (error) {
    console.error('Error fetching bandi data:', error);
    return { items: [], total: 0 };
  }
}

// Load filter options
async function loadFilterOptions() {
  try {
    if (!supabaseUrl || !supabaseKey) return { categorie: [], settori: [], sedi: [] };
    const supabase = createClient(supabaseUrl, supabaseKey);
    const { data } = await supabase
      .from('selezione_personale')
      .select('categorie, settori, sedi')
      .eq('status', 'completed');

    const categorie = new Set<string>();
    const settori = new Set<string>();
    const sedi = new Set<string>();

    (data || []).forEach((row: any) => {
      (row.categorie || []).forEach((c: string) => categorie.add(c));
      (row.settori || []).forEach((s: string) => settori.add(s));
      (row.sedi || []).forEach((s: string) => sedi.add(s));
    });

    return {
      categorie: [...categorie].sort(),
      settori: [...settori].sort(),
      sedi: [...sedi].sort(),
    };
  } catch {
    return { categorie: [], settori: [], sedi: [] };
  }
}

const { items: bandiData, total: totalCount } = await loadBandiData();
const totalPages = Math.ceil(totalCount / PAGE_SIZE);
const filterOptions = await loadFilterOptions();

const formatDate = (dateString: string): string => {
  try {
    const parsedDate = parseISO(dateString);
    if (!isValid(parsedDate)) return "Data non valida";
    return format(parsedDate, 'dd MMMM yyyy', { locale: it });
  } catch {
    return "Data non valida";
  }
};

const getStatusBadgeColor = (status: string): string => {
  switch (status) {
    case 'OPEN': return 'bg-green-100 text-green-800';
    case 'CLOSED': return 'bg-red-100 text-red-800';
    case 'PENDING': return 'bg-yellow-100 text-yellow-800';
    default: return 'bg-gray-100 text-gray-800';
  }
};

const getStatusBorderColorClass = (status: string): string => {
  switch (status) {
    case 'OPEN': return 'border-green-500';
    case 'CLOSED': return 'border-red-500';
    case 'PENDING': return 'border-yellow-500';
    default: return 'border-gray-300';
  }
};

const pageTitle = "Selezione Personale - EduNews24";
const pageDescription = "Con EduNews24.it ricerca degli annunci di lavoro della pubblica amministrazione e delle migliori aziende private";
const pageKeywords = "selezione personale, lavoro, ricerca lavoro, offerte lavoro, annunci lavoro, pubblica amministrazione, bandi pubblici, bandi e concorsi";
---
<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
>
  <main class="bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="mb-10 border-b pb-4">
        <h1 class="text-3xl md:text-4xl font-bold text-primary">Selezione Personale</h1>
        <p class="text-gray-600 mt-2">Bandi e concorsi pubblici in Italia</p>
      </div>

      {/* Filter Controls */}
      <div class="mb-8 p-4 bg-white rounded-md shadow-sm">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 items-end">
          {/* Search */}
          <div class="lg:col-span-2">
            <label for="search-filter" class="block text-sm font-medium text-gray-700 mb-1">Cerca</label>
            <input type="text" id="search-filter" placeholder="Titolo, Ente, Codice..." class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary text-sm">
          </div>

          {/* Categoria */}
          <div>
            <label for="category-filter" class="block text-sm font-medium text-gray-700 mb-1">Categoria</label>
            <select id="category-filter" class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary text-sm bg-white">
              <option value="">Tutte</option>
              {filterOptions.categorie.map(cat => <option value={cat}>{cat}</option>)}
            </select>
          </div>

          {/* Settore */}
          <div>
            <label for="settore-filter" class="block text-sm font-medium text-gray-700 mb-1">Settore</label>
            <select id="settore-filter" class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary text-sm bg-white">
              <option value="">Tutti</option>
              {filterOptions.settori.map(s => <option value={s}>{s}</option>)}
            </select>
          </div>

          {/* Reset Button */}
          <div class="flex items-end">
            <button id="reset-filters" class="w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
              Resetta
            </button>
          </div>
        </div>
      </div>

      {/* Results Count */}
      <div class="mb-4">
        <p id="results-count" class="text-sm text-gray-600">
          Trovati <span id="visible-count">{totalCount}</span> bandi
        </p>
      </div>

      <div id="bandi-list" class="space-y-5">
        {bandiData.length === 0 ? (
          <p id="no-results-message" class="text-center text-gray-500 text-lg py-10">Nessun bando trovato al momento.</p>
        ) : (
          <>
            {bandiData.map((bando: SelezioneBando) => (
              <article
                class:list={["bando-item bg-white rounded-md border overflow-hidden transition-colors duration-200 hover:border-gray-300", getStatusBorderColorClass(bando.calculated_status)]}
              >
                <a href={`/selezione-personale/${bando.slug}`} class="block hover:bg-gray-50/50">
                  <div class="p-5">
                    <div class="flex flex-col sm:flex-row justify-between sm:items-start gap-3 mb-4">
                      <div class="flex-1">
                        <h2 class="text-lg font-semibold text-gray-800 mb-1 hover:text-primary transition-colors">
                          {bando.article_title || bando.titolo}
                        </h2>
                        {(bando.enti_riferimento?.length > 0 || bando.sedi?.length > 0) && (
                          <p class="text-sm text-gray-500">
                            {bando.enti_riferimento?.length > 0 && (
                              <>
                                <span class="font-medium text-gray-600">Ente:</span> {bando.enti_riferimento.join(', ')}
                                {bando.sedi?.length > 0 && <span class="mx-1">|</span>}
                              </>
                            )}
                            {bando.sedi?.length > 0 && (
                              <>
                                <span class="font-medium text-gray-600">Sede:</span> {bando.sedi.join(', ')}
                              </>
                            )}
                          </p>
                        )}
                      </div>
                      <div class="flex-shrink-0 text-right space-y-1 pt-1">
                        <span class={`inline-block px-2.5 py-0.5 text-xs font-medium rounded-full ${getStatusBadgeColor(bando.calculated_status)}`}>
                          {bando.status_label}
                        </span>
                        <p class="text-xs text-gray-400">Cod. {bando.codice}</p>
                      </div>
                    </div>

                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-4 gap-y-3 mb-4 text-sm border-t border-gray-100 pt-4 mt-4">
                      {bando.figura_ricercata && (
                        <div>
                          <p class="text-xs text-gray-500 uppercase tracking-wider">Figura Ricercata</p>
                          <p class="font-medium text-gray-700">{bando.figura_ricercata}</p>
                        </div>
                      )}
                      {bando.num_posti && (
                        <div>
                          <p class="text-xs text-gray-500 uppercase tracking-wider">Posti</p>
                          <p class="font-medium text-gray-700">{bando.num_posti}</p>
                        </div>
                      )}
                      {bando.tipo_procedura && (
                        <div>
                          <p class="text-xs text-gray-500 uppercase tracking-wider">Procedura</p>
                          <p class="font-medium text-gray-700">{bando.tipo_procedura}</p>
                        </div>
                      )}
                      {bando.data_pubblicazione && (
                        <div class="sm:col-span-1">
                          <p class="text-xs text-gray-500 uppercase tracking-wider">Pubblicazione</p>
                          <p class="font-medium text-gray-700 text-xs">{formatDate(bando.data_pubblicazione)}</p>
                        </div>
                      )}
                      {bando.data_scadenza && (
                        <div class="sm:col-span-1">
                          <p class="text-xs text-gray-500 uppercase tracking-wider">Scadenza</p>
                          <p class="font-medium text-red-600 text-xs">{formatDate(bando.data_scadenza)}</p>
                        </div>
                      )}
                    </div>

                    {(bando.categorie?.length > 0 || bando.settori?.length > 0) && (
                      <div class="flex flex-wrap gap-x-3 gap-y-1 mb-4 pt-3 border-t border-gray-100 text-xs">
                        {bando.categorie?.map((cat: string) => <span class="text-gray-600 font-medium">{cat}</span>)}
                        {bando.settori?.map((sec: string) => <span class="text-blue-600 font-medium">{sec}</span>)}
                      </div>
                    )}

                    {bando.article_subtitle && (
                      <p class="text-gray-700 text-sm leading-relaxed">{bando.article_subtitle}</p>
                    )}
                  </div>
                </a>
              </article>
            ))}
            <p id="no-filtered-results-message" class="text-center text-gray-500 text-lg py-10 hidden">Nessun bando corrisponde ai filtri selezionati.</p>
          </>
        )}
      </div>

      {/* Pagination */}
      {totalPages > 1 && (
        <nav id="pagination" class="mt-8 flex justify-center items-center gap-2" data-total-pages={totalPages} data-page-size={PAGE_SIZE}>
          <button id="prev-page" class="px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
            &larr; Precedente
          </button>
          <span class="px-4 py-2 text-sm text-gray-600">
            Pagina <span id="current-page-num">1</span> di <span id="total-pages-num">{totalPages}</span>
          </span>
          <button id="next-page" class="px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed">
            Successiva &rarr;
          </button>
        </nav>
      )}
    </div>
  </main>
</Layout>

<style is:global>
.prose :where(p):not(:where([class~="not-prose"] *)) {
  margin-top: 0.5em;
  margin-bottom: 0.5em;
}
.prose a {
    color: #0056b3;
    text-decoration: none;
}
.prose a:hover {
    color: #003d80;
    text-decoration: underline;
}
.prose strong {
    font-weight: 600;
    color: #333;
}
</style>

<script is:inline define:vars={{ supabaseUrl, supabaseKey, PAGE_SIZE }}>
  async function supabaseFetch(table, params) {
    const url = new URL(`${supabaseUrl}/rest/v1/${table}`);
    Object.entries(params).forEach(([k, v]) => url.searchParams.set(k, v));
    const res = await fetch(url.toString(), {
      headers: {
        'apikey': supabaseKey,
        'Authorization': `Bearer ${supabaseKey}`,
        'Prefer': 'count=exact',
      },
    });
    const total = parseInt(res.headers.get('content-range')?.split('/')[1] || '0', 10);
    const data = await res.json();
    return { data, total };
  }

  const searchInput = document.getElementById('search-filter');
  const categorySelect = document.getElementById('category-filter');
  const settoreSelect = document.getElementById('settore-filter');
  const bandiList = document.getElementById('bandi-list');
  const noFilteredResultsMessage = document.getElementById('no-filtered-results-message');
  const resetButton = document.getElementById('reset-filters');
  const visibleCountSpan = document.getElementById('visible-count');
  const prevBtn = document.getElementById('prev-page');
  const nextBtn = document.getElementById('next-page');
  const currentPageNum = document.getElementById('current-page-num');
  const totalPagesNum = document.getElementById('total-pages-num');

  let currentPage = 1;
  let isLoading = false;

  function formatDateDisplay(dateString) {
    try {
      const d = new Date(dateString);
      if (isNaN(d.getTime())) return 'Data non valida';
      return d.toLocaleDateString('it-IT', { day: '2-digit', month: 'long', year: 'numeric' });
    } catch { return 'Data non valida'; }
  }

  function getStatusBadge(status, label) {
    const colors = {
      'OPEN': 'bg-green-100 text-green-800',
      'CLOSED': 'bg-red-100 text-red-800',
      'PENDING': 'bg-yellow-100 text-yellow-800',
    };
    const borderColors = {
      'OPEN': 'border-green-500',
      'CLOSED': 'border-red-500',
      'PENDING': 'border-yellow-500',
    };
    return { badge: colors[status] || 'bg-gray-100 text-gray-800', border: borderColors[status] || 'border-gray-300' };
  }

  function renderItems(items) {
    const existingItems = bandiList.querySelectorAll('.bando-item');
    existingItems.forEach(el => el.remove());

    if (items.length === 0) {
      if (noFilteredResultsMessage) noFilteredResultsMessage.classList.remove('hidden');
      return;
    }
    if (noFilteredResultsMessage) noFilteredResultsMessage.classList.add('hidden');

    const fragment = document.createDocumentFragment();
    items.forEach(item => {
      const { badge, border } = getStatusBadge(item.calculated_status, item.status_label);
      const article = document.createElement('article');
      article.className = `bando-item bg-white rounded-md border overflow-hidden transition-colors duration-200 hover:border-gray-300 ${border}`;

      const enti = (item.enti_riferimento || []).join(', ');
      const sedi = (item.sedi || []).join(', ');
      const categorie = (item.categorie || []).map(c => `<span class="text-gray-600 font-medium">${c}</span>`).join('');
      const settori = (item.settori || []).map(s => `<span class="text-blue-600 font-medium">${s}</span>`).join('');

      article.innerHTML = `
        <a href="/selezione-personale/${item.slug}" class="block hover:bg-gray-50/50">
          <div class="p-5">
            <div class="flex flex-col sm:flex-row justify-between sm:items-start gap-3 mb-4">
              <div class="flex-1">
                <h2 class="text-lg font-semibold text-gray-800 mb-1 hover:text-primary transition-colors">
                  ${item.article_title || item.titolo || ''}
                </h2>
                ${(enti || sedi) ? `<p class="text-sm text-gray-500">
                  ${enti ? `<span class="font-medium text-gray-600">Ente:</span> ${enti}` : ''}
                  ${enti && sedi ? '<span class="mx-1">|</span>' : ''}
                  ${sedi ? `<span class="font-medium text-gray-600">Sede:</span> ${sedi}` : ''}
                </p>` : ''}
              </div>
              <div class="flex-shrink-0 text-right space-y-1 pt-1">
                <span class="inline-block px-2.5 py-0.5 text-xs font-medium rounded-full ${badge}">
                  ${item.status_label || ''}
                </span>
                <p class="text-xs text-gray-400">Cod. ${item.codice || ''}</p>
              </div>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-4 gap-y-3 mb-4 text-sm border-t border-gray-100 pt-4 mt-4">
              ${item.figura_ricercata ? `<div><p class="text-xs text-gray-500 uppercase tracking-wider">Figura Ricercata</p><p class="font-medium text-gray-700">${item.figura_ricercata}</p></div>` : ''}
              ${item.num_posti ? `<div><p class="text-xs text-gray-500 uppercase tracking-wider">Posti</p><p class="font-medium text-gray-700">${item.num_posti}</p></div>` : ''}
              ${item.tipo_procedura ? `<div><p class="text-xs text-gray-500 uppercase tracking-wider">Procedura</p><p class="font-medium text-gray-700">${item.tipo_procedura}</p></div>` : ''}
              ${item.data_pubblicazione ? `<div class="sm:col-span-1"><p class="text-xs text-gray-500 uppercase tracking-wider">Pubblicazione</p><p class="font-medium text-gray-700 text-xs">${formatDateDisplay(item.data_pubblicazione)}</p></div>` : ''}
              ${item.data_scadenza ? `<div class="sm:col-span-1"><p class="text-xs text-gray-500 uppercase tracking-wider">Scadenza</p><p class="font-medium text-red-600 text-xs">${formatDateDisplay(item.data_scadenza)}</p></div>` : ''}
            </div>
            ${(categorie || settori) ? `<div class="flex flex-wrap gap-x-3 gap-y-1 mb-4 pt-3 border-t border-gray-100 text-xs">${categorie}${settori}</div>` : ''}
            ${item.article_subtitle ? `<p class="text-gray-700 text-sm leading-relaxed">${item.article_subtitle}</p>` : ''}
          </div>
        </a>`;
      fragment.appendChild(article);
    });

    if (noFilteredResultsMessage) {
      bandiList.insertBefore(fragment, noFilteredResultsMessage);
    } else {
      bandiList.appendChild(fragment);
    }
  }

  function updatePagination(total) {
    const pages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (currentPageNum) currentPageNum.textContent = currentPage;
    if (totalPagesNum) totalPagesNum.textContent = pages;
    if (prevBtn) prevBtn.disabled = currentPage <= 1;
    if (nextBtn) nextBtn.disabled = currentPage >= pages;
    const paginationNav = document.getElementById('pagination');
    if (paginationNav) paginationNav.style.display = pages <= 1 ? 'none' : 'flex';
  }

  async function loadPage() {
    if (isLoading) return;
    isLoading = true;

    const searchTerm = searchInput?.value?.trim() || '';
    const category = categorySelect?.value || '';
    const settore = settoreSelect?.value || '';

    const from = (currentPage - 1) * PAGE_SIZE;

    const params = {
      'select': '*',
      'status': 'eq.completed',
      'order': 'data_pubblicazione.desc',
      'offset': from.toString(),
      'limit': PAGE_SIZE.toString(),
    };

    if (searchTerm) {
      params['or'] = `(article_title.ilike.*${searchTerm}*,titolo.ilike.*${searchTerm}*,codice.ilike.*${searchTerm}*)`;
    }
    if (category) {
      params['categorie'] = `cs.{${category}}`;
    }
    if (settore) {
      params['settori'] = `cs.{${settore}}`;
    }

    try {
      const { data, total } = await supabaseFetch('selezione_personale', params);
      renderItems(data || []);
      if (visibleCountSpan) visibleCountSpan.textContent = total;
      updatePagination(total);
    } catch (e) {
      console.error('Errore caricamento bandi:', e);
    } finally {
      isLoading = false;
    }
  }

  function resetAndLoad() {
    currentPage = 1;
    loadPage();
  }

  function debounce(func, wait) {
    let timeout;
    return (...args) => {
      clearTimeout(timeout);
      timeout = setTimeout(() => func(...args), wait);
    };
  }

  const debouncedLoad = debounce(resetAndLoad, 300);

  if (searchInput) searchInput.addEventListener('input', debouncedLoad);
  if (categorySelect) categorySelect.addEventListener('change', resetAndLoad);
  if (settoreSelect) settoreSelect.addEventListener('change', resetAndLoad);

  if (prevBtn) prevBtn.addEventListener('click', () => {
    if (currentPage > 1) { currentPage--; loadPage(); }
  });
  if (nextBtn) nextBtn.addEventListener('click', () => {
    currentPage++;
    loadPage();
  });

  if (resetButton) {
    resetButton.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      if (categorySelect) categorySelect.value = '';
      if (settoreSelect) settoreSelect.value = '';
      resetAndLoad();
    });
  }
</script>
