---
import { categories, refreshCategories } from '../lib/categories';
import { supabase } from '../lib/supabase';
import { getArticleUrl } from '../lib/utils';

// Guard for cold start
if (categories.length === 0) {
  await refreshCategories();
}

// Fetch latest 3 articles per category in parallel
const results = await Promise.all(
  categories.map(async (cat) => {
    const { data } = await supabase
      .from('articles')
      .select('id, title, slug, category, category_slug, image_url, published_at')
      .eq('category_slug', cat.slug)
      .eq('isdraft', false)
      .order('published_at', { ascending: false })
      .limit(3);
    return { category: cat, articles: data || [] };
  })
);

// Filter out categories with no articles
const categoriesWithArticles = results.filter((r) => r.articles.length > 0);
---

<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>EduNews24 - Link in Bio</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        min-height: 100vh;
        background: linear-gradient(to bottom, #004e9c, #001a3a);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      }
      .container {
        max-width: 32rem;
        margin: 0 auto;
        padding: 2rem 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }
      .logo {
        width: 5rem;
        height: 5rem;
        border-radius: 9999px;
        object-fit: cover;
      }
      h1 {
        color: white;
        font-size: 1.5rem;
        font-weight: 700;
      }
      .btn-site {
        display: block;
        width: 100%;
        text-align: center;
        padding: 0.875rem 1.5rem;
        background: white;
        color: #004e9c;
        font-weight: 700;
        font-size: 1rem;
        border-radius: 9999px;
        text-decoration: none;
        transition: opacity 0.2s;
      }
      .btn-site:hover { opacity: 0.9; }
      .category-section {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .category-header {
        text-transform: uppercase;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-align: center;
      }
      .btn-article {
        display: block;
        width: 100%;
        text-align: center;
        padding: 0.75rem 1.5rem;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(4px);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 9999px;
        text-decoration: none;
        font-size: 0.875rem;
        transition: background 0.2s;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .footer {
        margin-top: 1rem;
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.75rem;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <img src="/logo.png" alt="EduNews24" class="logo" />
      <h1>EduNews24</h1>

      <a href="https://edunews24.it" class="btn-site">Vai al sito</a>

      {categoriesWithArticles.map(({ category: cat, articles }) => (
        <div class="category-section">
          <div class="category-header" style={`color: ${cat.color}`}>
            {cat.name}
          </div>
          {articles.map((article) => (
            <a
              href={`https://edunews24.it${getArticleUrl(article)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-article"
              style={`--hover-bg: ${cat.color}`}
              onmouseover={`this.style.background='${cat.color}'`}
              onmouseout={`this.style.background='rgba(255,255,255,0.1)'`}
            >
              {article.title}
            </a>
          ))}
        </div>
      ))}

      <div class="footer">
        &copy; {new Date().getFullYear()} EduNews24. Tutti i diritti riservati.
      </div>
    </div>
  </body>
</html>
