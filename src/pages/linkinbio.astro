<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>EduNews24 - Link in Bio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        min-height: 100vh;
        background: #0a0f1a;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        overflow-x: hidden;
      }

      .bg-glow {
        position: fixed;
        inset: 0;
        z-index: 0;
        overflow: hidden;
      }
      .bg-glow::before {
        content: '';
        position: absolute;
        top: -40%;
        left: 50%;
        transform: translateX(-50%);
        width: 140%;
        height: 60%;
        background: radial-gradient(ellipse at center, rgba(6, 76, 153, 0.35) 0%, transparent 70%);
      }
      .bg-glow::after {
        content: '';
        position: absolute;
        bottom: -20%;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        height: 40%;
        background: radial-gradient(ellipse at center, rgba(6, 76, 153, 0.15) 0%, transparent 70%);
      }

      .container {
        position: relative;
        z-index: 1;
        max-width: 28rem;
        margin: 0 auto;
        padding: 3rem 1.25rem 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.75rem;
      }

      /* Header */
      .profile {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }
      .brand-name svg {
        height: 2.75rem;
        width: auto;
      }
      .tagline {
        color: rgba(255,255,255,0.5);
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      /* CTA button */
      .btn-site {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        text-align: center;
        padding: 1rem 1.5rem;
        background: linear-gradient(135deg, #064C99, #0a6dd6);
        color: #fff;
        font-weight: 700;
        font-size: 1rem;
        border-radius: 1rem;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 20px rgba(6, 76, 153, 0.4);
        letter-spacing: 0.02em;
      }
      .btn-site:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(6, 76, 153, 0.55);
      }
      .btn-site svg {
        width: 1.1rem;
        height: 1.1rem;
        transition: transform 0.3s ease;
      }
      .btn-site:hover svg {
        transform: translateX(3px);
      }

      /* Category sections */
      .category-section {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
      }
      .category-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0 0.25rem;
        margin-bottom: 0.125rem;
      }
      .category-dot {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 9999px;
        flex-shrink: 0;
      }
      .category-name {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .category-line {
        flex: 1;
        height: 1px;
        opacity: 0.25;
      }

      /* Article buttons */
      .btn-article {
        display: flex;
        align-items: center;
        width: 100%;
        padding: 0.875rem 1rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 0.875rem;
        text-decoration: none;
        transition: all 0.25s ease;
        gap: 0.75rem;
        backdrop-filter: blur(8px);
      }
      .btn-article:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.15);
        transform: translateY(-1px);
      }
      .article-color-bar {
        width: 3px;
        height: 1.75rem;
        border-radius: 2px;
        flex-shrink: 0;
      }
      .article-title {
        color: rgba(255, 255, 255, 0.9);
        font-size: 0.84rem;
        font-weight: 500;
        line-height: 1.4;
        flex: 1;
        min-width: 0;
      }
      .article-arrow {
        flex-shrink: 0;
        width: 1rem;
        height: 1rem;
        color: rgba(255, 255, 255, 0.25);
        transition: all 0.25s ease;
      }
      .btn-article:hover .article-arrow {
        color: rgba(255, 255, 255, 0.6);
        transform: translateX(2px);
      }

      /* Social bar */
      .social-bar {
        display: flex;
        gap: 1rem;
        margin-top: 0.5rem;
      }
      .social-link {
        width: 2.5rem;
        height: 2.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.75rem;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.5);
        transition: all 0.25s ease;
        text-decoration: none;
      }
      .social-link:hover {
        background: rgba(255, 255, 255, 0.12);
        color: white;
        transform: translateY(-2px);
      }
      .social-link svg {
        width: 1.15rem;
        height: 1.15rem;
      }

      /* Footer */
      .footer {
        margin-top: 0.5rem;
        color: rgba(255, 255, 255, 0.2);
        font-size: 0.7rem;
        text-align: center;
        letter-spacing: 0.03em;
      }

      /* Fade-in animation */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-in {
        animation: fadeUp 0.5s ease-out both;
      }
    </style>
  </head>
  <body>
