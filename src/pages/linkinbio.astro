            </div>
          );
        }

        const rawItem = item as RawItem;

        if (rawItem.type === 'header') {
          return (
            <div class="category-section animate-in" style={`animation-delay: ${0.15 + i * 0.05}s`}>
              <div class="category-header">
                <div class="category-dot" style={`background: ${rawItem.color || '#064C99'}`}></div>
                <span class="category-name" style={`color: ${rawItem.color || '#064C99'}`}>{rawItem.title}</span>
                <div class="category-line" style={`background: ${rawItem.color || '#064C99'}`}></div>
              </div>
            </div>
          );
        }

        if (rawItem.type === 'separator') {
          return <div class="animate-in" style={`animation-delay: ${0.15 + i * 0.05}s; height: 1rem;`}></div>;
        }

        if (rawItem.type === 'article' && rawItem.articles) {
          const art = rawItem.articles as { id: number; title: string; slug: string; category: string; category_slug: string; image_url: string };
          return (
            <a href={`https://edunews24.it${getArticleUrl(art)}`} target="_blank" rel="noopener noreferrer"
              class="btn-article animate-in" style={`animation-delay: ${0.15 + i * 0.05}s`}>
              <div class="article-color-bar" style={`background: ${rawItem.color || '#064C99'}`}></div>
              <span class="article-title">{art.title}</span>
              <svg class="article-arrow" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </a>
          );
        }

        if (rawItem.type === 'link') {
          return (
            <a href={rawItem.url || '#'} target={rawItem.open_in_new_tab ? '_blank' : '_self'} rel="noopener noreferrer"
              class="btn-article animate-in" style={`animation-delay: ${0.15 + i * 0.05}s`}>
              <div class="article-color-bar" style={`background: ${rawItem.color || '#064C99'}`}></div>
              <span class="article-title">{rawItem.title}</span>
              <svg class="article-arrow" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </a>
          );
        }

        return null;
      })}

      <!-- Footer -->
      <div class="footer animate-in" style={`animation-delay: ${0.15 + groupedItems.length * 0.05 + 0.1}s`}>
        &copy; {new Date().getFullYear()} EduNews24. Tutti i diritti riservati.
      </div>

    </div>
  </body>
</html>
