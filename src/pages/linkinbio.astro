---
import { supabase } from '../lib/supabase';
import { slugify } from '../lib/utils';

const { data: items } = await supabase
  .from('linkinbio_items')
  .select('*, articles(id, title, slug, category, category_slug, image_url)')
  .eq('is_active', true)
  .order('position', { ascending: true });

const linkinbioItems = items || [];

// Helper to build article URL
function getArticleUrl(article: { category: string; title: string; slug?: string }): string {
  const categorySlug = slugify(article.category);
  const articleSlug = article.slug || slugify(article.title);
  return `/${categorySlug}/${articleSlug}`;
}

// Pre-process: group consecutive social items
type RawItem = (typeof linkinbioItems)[number];
type GroupedItem = { type: 'social_group'; items: RawItem[] } | RawItem;
const groupedItems: GroupedItem[] = [];
let socialBuffer: RawItem[] = [];

for (const item of linkinbioItems) {
  if (item.type === 'social') {
    socialBuffer.push(item);
  } else {
    if (socialBuffer.length > 0) {
      groupedItems.push({ type: 'social_group', items: [...socialBuffer] });
      socialBuffer = [];
    }
    groupedItems.push(item);
  }
}
if (socialBuffer.length > 0) {
  groupedItems.push({ type: 'social_group', items: socialBuffer });
}

