          return (
            <div class="social-bar animate-in" style={`animation-delay: ${0.15 + i * 0.05}s`}>
              {(item as { type: 'social_group'; items: RawItem[] }).items.map((s) => (
                <a href={s.url || '#'} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={s.icon || 'link'}>
