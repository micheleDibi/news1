---
import Layout from '../layouts/Layout.astro';
import { format, parseISO, isValid } from 'date-fns';
import { it } from 'date-fns/locale';
import { createClient } from '@supabase/supabase-js';

// Define the Interpello type
interface Interpello {
  id?: number;
  interpello_name: string;
  interpello_date: string;
  interpello_description: string;
  interpello_link: string;
  interpello_regione?: string;
  interpello_provincia?: string;
  interpello_citta?: string;
  classe_concorso?: string;
  article_title?: string;
  article_subtitle?: string;
  created_at?: string;
}

// Function to generate URL-friendly slug from interpello data
function generateInterpelloSlug(interpello: Interpello): string {
  const parts = [
    interpello.interpello_name,
    interpello.interpello_provincia || interpello.interpello_citta,
    interpello.interpello_regione,
    interpello.id?.toString()
  ].filter(Boolean);

  return parts
    .join('-')
    .toLowerCase()
    .replace(/[^a-z0-9\-]/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
}

// Initialize Supabase client
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const PAGE_SIZE = 20;

// Function to fetch interpelli data directly from Supabase
async function loadInterpelliData(): Promise<{ items: Interpello[], total: number }> {
  try {
    if (!supabaseUrl || !supabaseKey) {
      console.error('Missing Supabase environment variables');
      return { items: [], total: 0 };
    }

    const supabase = createClient(supabaseUrl, supabaseKey);

    const { count } = await supabase
      .from('interpelli')
      .select('*', { count: 'exact', head: true })
      .eq('link_type', 'single');

    const { data, error } = await supabase
      .from('interpelli')
      .select('*')
      .eq('link_type', 'single')
      .order('interpello_date', { ascending: false })
      .range(0, PAGE_SIZE - 1);

    if (error) {
      console.error('Supabase error:', error);
      return { items: [], total: 0 };
    }

    return { items: data || [], total: count || 0 };
  } catch (error) {
    console.error('Error fetching interpelli data:', error);
    return { items: [], total: 0 };
  }
}

// Load filter options (all unique regioni, province, classi)
async function loadFilterOptions() {
  try {
    if (!supabaseUrl || !supabaseKey) return { regioni: [], provinceByRegione: {}, classi: [] };
    const supabase = createClient(supabaseUrl, supabaseKey);
    const { data } = await supabase
      .from('interpelli')
      .select('interpello_regione, interpello_provincia, classe_concorso')
      .eq('link_type', 'single');

    const regioni = new Set<string>();
    const provinceByRegione: Record<string, Set<string>> = {};
    const classi = new Set<string>();

    (data || []).forEach((row: any) => {
      if (row.interpello_regione) {
        regioni.add(row.interpello_regione);
        if (!provinceByRegione[row.interpello_regione]) {
          provinceByRegione[row.interpello_regione] = new Set();
        }
        if (row.interpello_provincia) {
          provinceByRegione[row.interpello_regione].add(row.interpello_provincia);
        }
      }
      if (row.classe_concorso) classi.add(row.classe_concorso);
    });

    const sortedRegioni = [...regioni].sort();
    const sortedProvinceByRegione: Record<string, string[]> = {};
    for (const r of sortedRegioni) {
      sortedProvinceByRegione[r] = [...(provinceByRegione[r] || [])].sort();
    }

    return {
      regioni: sortedRegioni,
      provinceByRegione: sortedProvinceByRegione,
      classi: [...classi].sort(),
    };
  } catch {
    return { regioni: [], provinceByRegione: {}, classi: [] };
  }
}

const { items: interpelliData, total: totalCount } = await loadInterpelliData();
const totalPages = Math.ceil(totalCount / PAGE_SIZE);
const filterOptions = await loadFilterOptions();

const formatDate = (dateString: string): string => {
  try {
    const parsedDate = parseISO(dateString);
    if (!isValid(parsedDate)) return "Data non valida";
    return format(parsedDate, 'dd MMMM yyyy', { locale: it });
  } catch {
    return "Data non valida";
  }
};

const formatDateForDataAttr = (dateString: string): string => {
  try {
    const parsedDate = parseISO(dateString);
    if (!isValid(parsedDate)) return "";
    return format(parsedDate, 'yyyy-MM-dd');
  } catch {
    return "";
  }
};

const pageTitle = "Interpelli Scuola - EduNews24";
const pageDescription = "Trova tutti gli interpelli per la scuola divisi per regione, provincia e classe di concorso. Cerca opportunità di lavoro nella scuola pubblica italiana.";
const pageKeywords = "interpelli scuola, lavoro scuola, supplenze, interpelli insegnanti, opportunità scuola, lavoro pubblico scuola";
---
<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
  <main class="bg-gray-50 py-12">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="mb-10 border-b pb-4">
        <h1 class="text-3xl md:text-4xl font-bold text-primary">Interpelli Scuola</h1>
        <p class="text-gray-600 mt-2">Trova opportunità di lavoro nella scuola pubblica italiana</p>
      </div>

      {/* Filter Controls */}
      <div class="mb-8 p-4 bg-white rounded-md shadow-sm">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 items-end">
          {/* Search */}
          <div class="lg:col-span-2">
            <label for="search-filter" class="block text-sm font-medium text-gray-700 mb-1">Cerca</label>
            <input type="text" id="search-filter" placeholder="Nome interpello, descrizione..." class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary text-sm">
          </div>

          {/* Regione Filter */}
          <div>
            <label for="regione-filter" class="block text-sm font-medium text-gray-700 mb-1">Regione</label>
            <select id="regione-filter" class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary text-sm bg-white">
              <option value="">Tutte</option>
              {filterOptions.regioni.map(r => (
                <option value={r}>{r}</option>
              ))}
            </select>
          </div>

          {/* Provincia Filter */}
          <div>
            <label for="provincia-filter" class="block text-sm font-medium text-gray-700 mb-1">Provincia</label>
            <select id="provincia-filter" class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary text-sm bg-white" disabled>
              <option value="">Tutte</option>
            </select>
          </div>

          {/* Classe Concorso Filter */}
          <div>
            <label for="classe-filter" class="block text-sm font-medium text-gray-700 mb-1">Classe Concorso</label>
            <select id="classe-filter" class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary text-sm bg-white">
              <option value="">Tutte</option>
              {filterOptions.classi.map(c => (
                <option value={c}>{c}</option>
              ))}
            </select>
          </div>

          {/* Reset Button */}
          <div class="flex items-end">
            <button id="reset-filters" class="w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
              Resetta
            </button>
          </div>
        </div>
      </div>

      {/* Results Count */}
      <div class="mb-4">
        <p id="results-count" class="text-sm text-gray-600">
          Trovati <span id="visible-count">{totalCount}</span> interpelli
        </p>
      </div>

      <div id="interpelli-list" class="space-y-5">
        {interpelliData.length === 0 ? (
          <p id="no-results-message" class="text-center text-gray-500 text-lg py-10">Nessun interpello trovato al momento.</p>
        ) : (
          <>
            {interpelliData.map((interpello: Interpello) => (
              <a href={`/interpelli/${generateInterpelloSlug(interpello)}`} class="interpello-item block bg-white rounded-md border border-gray-200 overflow-hidden transition-all duration-200 hover:border-gray-300 hover:shadow-md">
                <div class="p-5">
                  <div class="flex flex-col sm:flex-row justify-between sm:items-start gap-3 mb-3">
                    <div class="flex-1">
                      <h2 class="text-lg font-semibold text-gray-800 mb-2 hover:text-primary transition-colors">
                        {interpello.article_title || interpello.interpello_name}
                      </h2>
                      <div class="flex flex-wrap items-center gap-2 text-sm text-gray-500 mb-3">
                        {interpello.interpello_regione && (
                          <span class="inline-flex items-center px-2 py-1 bg-blue-100 text-blue-800 rounded-md text-xs font-medium">
                            📍 {interpello.interpello_regione}
                          </span>
                        )}
                        {interpello.interpello_provincia && (
                          <span class="inline-flex items-center px-2 py-1 bg-green-100 text-green-800 rounded-md text-xs font-medium">
                            🏛️ {interpello.interpello_provincia}
                          </span>
                        )}
                        {interpello.interpello_citta && (
                          <span class="inline-flex items-center px-2 py-1 bg-teal-100 text-teal-800 rounded-md text-xs font-medium">
                            🏙️ {interpello.interpello_citta}
                          </span>
                        )}
                        {interpello.classe_concorso && (
                          <span class="inline-flex items-center px-2 py-1 bg-purple-100 text-purple-800 rounded-md text-xs font-medium">
                            🎓 {interpello.classe_concorso}
                          </span>
                        )}
                        {interpello.interpello_date && (
                          <span class="inline-flex items-center px-2 py-1 bg-gray-100 text-gray-800 rounded-md text-xs font-medium">
                            📅 {formatDate(interpello.interpello_date)}
                          </span>
                        )}
                      </div>
                    </div>
                  </div>
                  {(interpello.article_subtitle || interpello.interpello_description) && (
                    <p class="text-gray-700 text-sm leading-relaxed">
                      {interpello.article_subtitle || interpello.interpello_description}
                    </p>
                  )}
                </div>
              </a>
            ))}
            <p id="no-filtered-results-message" class="text-center text-gray-500 text-lg py-10 hidden">Nessun interpello corrisponde ai filtri selezionati.</p>
          </>
        )}
      </div>

      {/* Pagination */}
      {totalPages > 1 && (
        <nav id="pagination" class="mt-8 flex justify-center items-center gap-2" data-total-pages={totalPages} data-page-size={PAGE_SIZE}>
          <button id="prev-page" class="px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
            ← Precedente
          </button>
          <span class="px-4 py-2 text-sm text-gray-600">
            Pagina <span id="current-page-num">1</span> di <span id="total-pages-num">{totalPages}</span>
          </span>
          <button id="next-page" class="px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed">
            Successiva →
          </button>
        </nav>
      )}
    </div>
  </main>
</Layout>

<script is:inline define:vars={{ supabaseUrl, supabaseKey, PAGE_SIZE, provinceByRegione: filterOptions.provinceByRegione }}>
  // Supabase REST query helper
  async function supabaseFetch(table, params) {
    const url = new URL(`${supabaseUrl}/rest/v1/${table}`);
    Object.entries(params).forEach(([k, v]) => url.searchParams.set(k, v));
    const res = await fetch(url.toString(), {
      headers: {
        'apikey': supabaseKey,
        'Authorization': `Bearer ${supabaseKey}`,
        'Prefer': 'count=exact',
      },
    });
    const total = parseInt(res.headers.get('content-range')?.split('/')[1] || '0', 10);
    const data = await res.json();
    return { data, total };
  }

  const searchInput = document.getElementById('search-filter');
  const regioneSelect = document.getElementById('regione-filter');
  const provinciaSelect = document.getElementById('provincia-filter');
  const classeSelect = document.getElementById('classe-filter');
  const interpelliList = document.getElementById('interpelli-list');
  const noFilteredResultsMessage = document.getElementById('no-filtered-results-message');
  const resetButton = document.getElementById('reset-filters');
  const visibleCountSpan = document.getElementById('visible-count');
  const prevBtn = document.getElementById('prev-page');
  const nextBtn = document.getElementById('next-page');
  const currentPageNum = document.getElementById('current-page-num');
  const totalPagesNum = document.getElementById('total-pages-num');

  let currentPage = 1;
  let isLoading = false;

  // Cascading: aggiorna province quando cambia regione
  regioneSelect.addEventListener('change', () => {
    const regione = regioneSelect.value;
    provinciaSelect.innerHTML = '<option value="">Tutte</option>';
    if (regione && provinceByRegione[regione]) {
      provinceByRegione[regione].forEach(p => {
        const opt = document.createElement('option');
        opt.value = p;
        opt.textContent = p;
        provinciaSelect.appendChild(opt);
      });
      provinciaSelect.disabled = false;
    } else {
      provinciaSelect.disabled = true;
    }
    resetAndLoad();
  });

  function generateSlug(item) {
    return [item.interpello_name, item.interpello_provincia || item.interpello_citta, item.interpello_regione, item.id?.toString()]
      .filter(Boolean)
      .join('-')
      .toLowerCase()
      .replace(/[^a-z0-9\-]/g, '-')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '');
  }

  function formatDateDisplay(dateString) {
    try {
      const d = new Date(dateString + 'T00:00:00');
      if (isNaN(d.getTime())) return 'Data non valida';
      return d.toLocaleDateString('it-IT', { day: '2-digit', month: 'long', year: 'numeric' });
    } catch { return 'Data non valida'; }
  }

  function renderItems(items) {
    const existingItems = interpelliList.querySelectorAll('.interpello-item');
    existingItems.forEach(el => el.remove());

    if (items.length === 0) {
      if (noFilteredResultsMessage) noFilteredResultsMessage.classList.remove('hidden');
      return;
    }
    if (noFilteredResultsMessage) noFilteredResultsMessage.classList.add('hidden');

    const fragment = document.createDocumentFragment();
    items.forEach(item => {
      const a = document.createElement('a');
      a.href = `/interpelli/${generateSlug(item)}`;
      a.className = 'interpello-item block bg-white rounded-md border border-gray-200 overflow-hidden transition-all duration-200 hover:border-gray-300 hover:shadow-md';
      const dateFormatted = item.interpello_date ? formatDateDisplay(item.interpello_date) : '';

      a.innerHTML = `
        <div class="p-5">
          <div class="flex flex-col sm:flex-row justify-between sm:items-start gap-3 mb-3">
            <div class="flex-1">
              <h2 class="text-lg font-semibold text-gray-800 mb-2 hover:text-primary transition-colors">
                ${item.article_title || item.interpello_name || ''}
              </h2>
              <div class="flex flex-wrap items-center gap-2 text-sm text-gray-500 mb-3">
                ${item.interpello_regione ? `<span class="inline-flex items-center px-2 py-1 bg-blue-100 text-blue-800 rounded-md text-xs font-medium">📍 ${item.interpello_regione}</span>` : ''}
                ${item.interpello_provincia ? `<span class="inline-flex items-center px-2 py-1 bg-green-100 text-green-800 rounded-md text-xs font-medium">🏛️ ${item.interpello_provincia}</span>` : ''}
                ${item.interpello_citta ? `<span class="inline-flex items-center px-2 py-1 bg-teal-100 text-teal-800 rounded-md text-xs font-medium">🏙️ ${item.interpello_citta}</span>` : ''}
                ${item.classe_concorso ? `<span class="inline-flex items-center px-2 py-1 bg-purple-100 text-purple-800 rounded-md text-xs font-medium">🎓 ${item.classe_concorso}</span>` : ''}
                ${dateFormatted ? `<span class="inline-flex items-center px-2 py-1 bg-gray-100 text-gray-800 rounded-md text-xs font-medium">📅 ${dateFormatted}</span>` : ''}
              </div>
            </div>
          </div>
          ${(item.article_subtitle || item.interpello_description) ? `<p class="text-gray-700 text-sm leading-relaxed">${item.article_subtitle || item.interpello_description}</p>` : ''}
        </div>`;
      fragment.appendChild(a);
    });

    if (noFilteredResultsMessage) {
      interpelliList.insertBefore(fragment, noFilteredResultsMessage);
    } else {
      interpelliList.appendChild(fragment);
    }
  }

  function updatePagination(total) {
    const pages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (currentPageNum) currentPageNum.textContent = currentPage;
    if (totalPagesNum) totalPagesNum.textContent = pages;
    if (prevBtn) prevBtn.disabled = currentPage <= 1;
    if (nextBtn) nextBtn.disabled = currentPage >= pages;
    const paginationNav = document.getElementById('pagination');
    if (paginationNav) paginationNav.style.display = pages <= 1 ? 'none' : 'flex';
  }

  async function loadPage() {
    if (isLoading) return;
    isLoading = true;

    const searchTerm = searchInput?.value?.trim() || '';
    const regione = regioneSelect?.value || '';
    const provincia = provinciaSelect?.value || '';
    const classe = classeSelect?.value || '';

    const from = (currentPage - 1) * PAGE_SIZE;

    const params = {
      'select': '*',
      'link_type': 'eq.single',
      'order': 'interpello_date.desc',
      'offset': from.toString(),
      'limit': PAGE_SIZE.toString(),
    };

    if (searchTerm) {
      params['or'] = `(article_title.ilike.*${searchTerm}*,article_subtitle.ilike.*${searchTerm}*,interpello_name.ilike.*${searchTerm}*,interpello_description.ilike.*${searchTerm}*)`;
    }
    if (regione) {
      params['interpello_regione'] = `eq.${regione}`;
    }
    if (provincia) {
      params['interpello_provincia'] = `eq.${provincia}`;
    }
    if (classe) {
      params['classe_concorso'] = `eq.${classe}`;
    }

    try {
      const { data, total } = await supabaseFetch('interpelli', params);
      renderItems(data || []);
      if (visibleCountSpan) visibleCountSpan.textContent = total;
      updatePagination(total);
    } catch (e) {
      console.error('Errore caricamento interpelli:', e);
    } finally {
      isLoading = false;
    }
  }

  function resetAndLoad() {
    currentPage = 1;
    loadPage();
  }

  function debounce(func, wait) {
    let timeout;
    return (...args) => {
      clearTimeout(timeout);
      timeout = setTimeout(() => func(...args), wait);
    };
  }

  const debouncedLoad = debounce(resetAndLoad, 300);

  if (searchInput) searchInput.addEventListener('input', debouncedLoad);
  if (provinciaSelect) provinciaSelect.addEventListener('change', resetAndLoad);
  if (classeSelect) classeSelect.addEventListener('change', resetAndLoad);

  if (prevBtn) prevBtn.addEventListener('click', () => {
    if (currentPage > 1) { currentPage--; loadPage(); }
  });
  if (nextBtn) nextBtn.addEventListener('click', () => {
    currentPage++;
    loadPage();
  });

  if (resetButton) {
    resetButton.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      if (regioneSelect) regioneSelect.value = '';
      if (provinciaSelect) { provinciaSelect.value = ''; provinciaSelect.innerHTML = '<option value="">Tutte</option>'; provinciaSelect.disabled = true; }
      if (classeSelect) classeSelect.value = '';
      resetAndLoad();
    });
  }
</script>
