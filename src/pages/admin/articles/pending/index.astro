---
export const prerender = false;

import AdminLayout from '../../../../layouts/AdminLayout.astro';

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, proxy-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');
Astro.response.headers.set('Expires', '0');
Astro.response.headers.set('Surrogate-Control', 'no-store');
---

<style is:global>
  @keyframes progress-indet {
    0%   { margin-left: -40%; }
    100% { margin-left: 100%; }
  }
</style>

<!-- Loading screen -->
<div id="loading-screen" class="fixed inset-0 bg-white z-50 flex items-center justify-center">
  <div class="text-center">
    <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-sport-500 mb-4"></div>
    <p class="text-sport-600">Caricamento...</p>
  </div>
</div>

<div id="admin-content" class="hidden">
  <AdminLayout title="Articoli da Generare">
    <div class="py-6">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        <div class="md:flex md:items-center md:justify-between mb-6">
          <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
              Articoli da Generare
            </h2>
            <p class="mt-1 text-sm text-gray-500">
              Articoli raccolti e riassunti dalla pipeline. Clicca su un articolo per revisionarlo e generare l'articolo completo.
            </p>
          </div>
        </div>

        <!-- Search & Filters -->
        <div class="bg-white shadow rounded-lg mb-6">
          <div class="p-4">
            <div class="flex flex-col md:flex-row gap-4">
              <div class="flex-1">
                <div class="relative rounded-md shadow-sm">
                  <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                  </div>
                  <input
                    type="search"
                    id="search"
                    class="focus:ring-sport-500 focus:border-sport-500 block w-full pl-10 sm:text-sm border-gray-300 rounded-md"
                    placeholder="Cerca per titolo..."
                  />
                </div>
              </div>
              <div class="w-full md:w-48">
                <select
                  id="category-filter"
                  class="block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-sport-500 focus:border-sport-500 sm:text-sm rounded-md"
                >
                  <option value="all">Tutte le Categorie</option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <!-- Empty state -->
        <div id="empty-state" class="hidden text-center py-12">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">Nessun articolo in attesa</h3>
          <p class="mt-1 text-sm text-gray-500">La pipeline non ha ancora generato nuovi riassunti.</p>
        </div>

        <!-- Articles list -->
        <div id="pending-list-container" class="bg-white shadow overflow-hidden sm:rounded-md">
          <ul id="pending-list" class="divide-y divide-gray-200">
          </ul>
        </div>

        <!-- Pagination -->
        <div id="pagination" class="hidden mt-6 flex items-center justify-between">
          <button
            id="prev-page"
            class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed"
            disabled
          >
            <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Precedente
          </button>
          <span id="page-info" class="text-sm text-gray-700"></span>
          <button
            id="next-page"
            class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed"
            disabled
          >
            Successiva
            <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </AdminLayout>
</div>

<script>
  import { supabase } from '../../../../lib/supabase';

  const ITEMS_PER_PAGE = 15;
  let allArticles: any[] = [];
  let currentPage = 1;

  async function checkAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.href = '/login'; return; }

    const { data: profile, error } = await supabase
      .from('profiles')
      .select('role, permissions')
      .eq('id', session.user.id)
      .single();

    if (error || !(profile?.role === 'admin' || profile?.role === 'redattore' || profile?.role === 'giornalista' || profile?.role === 'direttore' || profile?.role === 'docente' || profile?.role === 'insegnante')) {
      window.location.href = '/login';
      return;
    }

    document.getElementById('loading-screen')?.classList.add('hidden');
    document.getElementById('admin-content')?.classList.remove('hidden');

    await loadPendingArticles();
    startPolling();
  }

  function getFilteredArticles() {
    const searchTerm = (document.getElementById('search') as HTMLInputElement)?.value.toLowerCase() || '';
    const category = (document.getElementById('category-filter') as HTMLSelectElement)?.value || 'all';

    return allArticles.filter(item => {
      const matchesSearch = !searchTerm || (item.title || '').toLowerCase().includes(searchTerm);
      const matchesCategory = category === 'all' || item.category === category;
      return matchesSearch && matchesCategory;
    });
  }

  function renderPage() {
    const filtered = getFilteredArticles();
    const totalPages = Math.max(1, Math.ceil(filtered.length / ITEMS_PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;

    const start = (currentPage - 1) * ITEMS_PER_PAGE;
    const pageItems = filtered.slice(start, start + ITEMS_PER_PAGE);

    const list = document.getElementById('pending-list');
    const emptyState = document.getElementById('empty-state');
    const container = document.getElementById('pending-list-container');
    const pagination = document.getElementById('pagination');

    if (filtered.length === 0) {
      if (emptyState) emptyState.classList.remove('hidden');
      if (container) container.classList.add('hidden');
      if (pagination) pagination.classList.add('hidden');
      return;
    }

    if (emptyState) emptyState.classList.add('hidden');
    if (container) container.classList.remove('hidden');

    if (list) {
      list.innerHTML = pageItems.map((item: any) => {
        const isGenerating = !!item.is_generating;
        const hostname = item.url ? (() => { try { return new URL(item.url).hostname.replace(/^www\./, ''); } catch { return item.url; } })() : '';
        const facts = item.facts && item.facts.length > 0 ? item.facts[0] : (item.context ? item.context.substring(0, 120) + '...' : '');
        const editHref = `/admin/articles/0/edit?newsId=${item.id}`;
        const dateStr = item.date_scraped ? new Date(item.date_scraped).toLocaleDateString('it-IT') : '';

        // Stato "in generazione": link disabilitato, barra indeterminata,
        // nessun bottone di modifica o scarto (per evitare race con il BG task).
        if (isGenerating) {
          return `
            <li class="px-4 py-4 sm:px-6 bg-indigo-50/40 border-l-4 border-indigo-400">
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 mt-1">
                  <svg class="animate-spin h-5 w-5 text-indigo-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <p class="text-sm font-medium text-gray-700 truncate">${item.title || 'Senza titolo'}</p>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-indigo-100 text-indigo-700 uppercase tracking-wide">In generazione</span>
                  </div>
                  <p class="mt-1 text-xs text-gray-500 line-clamp-1">${facts}</p>
                  <div class="mt-2 w-full bg-indigo-100 rounded-full h-1.5 overflow-hidden">
                    <div class="h-1.5 bg-indigo-400 rounded-full animate-[progress-indet_1.8s_ease-in-out_infinite]" style="width:40%"></div>
                  </div>
                  <div class="mt-2 flex items-center gap-3 flex-wrap">
                    ${item.category ? `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">${item.category}</span>` : ''}
                    ${item.url ? `<a href="${item.url}" target="_blank" rel="noopener noreferrer" class="text-xs text-gray-500 hover:text-indigo-600 flex items-center gap-1"><svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>${hostname}</a>` : ''}
                    <span class="text-xs text-gray-400">${dateStr}</span>
                    <span class="text-[11px] text-gray-400 italic">La skill sta lavorando... tempo tipico 5-7 minuti.</span>
                  </div>
                </div>
              </div>
            </li>
          `;
        }

        // Stato normale
        return `
          <li class="flex items-center hover:bg-gray-50 px-4 py-4 sm:px-6">
            <a href="${editHref}" class="block flex-1 min-w-0">
              <p class="text-sm font-medium text-primary truncate">${item.title || 'Senza titolo'}</p>
              <p class="mt-1 text-sm text-gray-500 line-clamp-1">${facts}</p>
              <div class="mt-1 flex items-center gap-3 flex-wrap">
                ${item.category ? `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">${item.category}</span>` : ''}
                ${item.url ? `<a href="${item.url}" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()" class="text-xs text-gray-500 hover:text-indigo-600 flex items-center gap-1"><svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>${hostname}</a>` : ''}
                <span class="text-xs text-gray-400">${dateStr}</span>
              </div>
            </a>
            <a
              href="${editHref}"
              class="ml-2 flex-shrink-0 p-2 text-gray-400 hover:text-primary rounded-full hover:bg-gray-100 transition-colors"
              title="Modifica"
            >
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
            </a>
            <button
              data-news-id="${item.id}"
              class="discard-btn flex-shrink-0 p-2 text-gray-400 hover:text-red-600 rounded-full hover:bg-red-50 transition-colors"
              title="Scarta articolo"
            >
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </button>
          </li>
        `;
      }).join('');

      setupDiscardButtons();
    }

    // Update pagination
    if (pagination) {
      if (totalPages > 1) {
        pagination.classList.remove('hidden');
        const pageInfo = document.getElementById('page-info');
        const prevBtn = document.getElementById('prev-page') as HTMLButtonElement;
        const nextBtn = document.getElementById('next-page') as HTMLButtonElement;

        if (pageInfo) pageInfo.innerHTML = `Pagina <span class="font-medium">${currentPage}</span> di <span class="font-medium">${totalPages}</span> (${filtered.length} articoli)`;
        if (prevBtn) { prevBtn.disabled = currentPage === 1; }
        if (nextBtn) { nextBtn.disabled = currentPage === totalPages; }
      } else {
        pagination.classList.add('hidden');
      }
    }
  }

  function setupDiscardButtons() {
    document.querySelectorAll('.discard-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        const newsId = (e.currentTarget as HTMLElement).dataset.newsId;
        if (!newsId || !confirm('Sei sicuro di voler scartare questo articolo?')) return;
        try {
          const res = await fetch(`/api/news/${newsId}`, { method: 'DELETE' });
          if (res.ok) {
            allArticles = allArticles.filter(a => String(a.id) !== newsId);
            renderPage();
          }
        } catch (err) {
          console.error('Error discarding article:', err);
        }
      });
    });
  }

  async function fetchWithRetry(url: string, attempts = 3, timeoutMs = 10000): Promise<any[]> {
    // Retry con backoff 500ms, 1500ms. Timeout per tentativo via AbortController
    // per evitare che il fetch resti appeso quando il proxy / reverse proxy
    // chiude la connessione.
    let lastErr: any;
    for (let i = 0; i < attempts; i++) {
      const ctrl = new AbortController();
      const t = setTimeout(() => ctrl.abort(), timeoutMs);
      try {
        const res = await fetch(url, { cache: 'no-store', signal: ctrl.signal });
        clearTimeout(t);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        return (await res.json()) || [];
      } catch (err) {
        clearTimeout(t);
        lastErr = err;
        if (i < attempts - 1) {
          await new Promise(r => setTimeout(r, 500 * (i + 1) * (i + 1)));
        }
      }
    }
    throw lastErr;
  }

  async function loadPendingArticles(isPoll = false) {
    try {
      const newData = await fetchWithRetry('/api/news/pending-review');

      // Al primo load popoliamo anche il filtro categorie. In polling non lo tocchiamo.
      if (!isPoll) {
        const categories = [...new Set(newData.map((a: any) => a.category).filter(Boolean))].sort();
        const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement;
        if (categoryFilter) {
          categories.forEach(cat => {
            const option = document.createElement('option');
            option.value = cat as string;
            option.textContent = cat as string;
            categoryFilter.appendChild(option);
          });
        }
      }

      allArticles = newData;
      renderPage();
    } catch (err: any) {
      // In polling non alarmiamo: il fetch ha gia' provato 3 volte, manteniamo
      // i dati precedenti in lista e riproviamo al prossimo tick.
      if (isPoll) {
        console.warn('Polling pending-review failed (keeping previous data):', err?.message || err);
        return;
      }
      console.error('Error loading pending articles:', err);
      // Primo load fallito: mostra stato vuoto con invito a ricaricare
      const list = document.getElementById('pending-list');
      const container = document.getElementById('pending-list-container');
      if (container && list) {
        container.classList.remove('hidden');
        list.innerHTML = `
          <li class="px-4 py-8 text-center">
            <p class="text-sm text-gray-600">Impossibile caricare gli articoli. Riprova.</p>
            <button onclick="window.location.reload()" class="mt-2 px-3 py-1.5 text-xs font-medium text-white bg-indigo-600 rounded hover:bg-indigo-700">Ricarica</button>
          </li>`;
      }
    }
  }

  // Polling: ogni 10s ricarica la lista se c'e' almeno un articolo in generazione
  // (o se la lista e' vuota, per intercettare nuove news arrivate dalla pipeline).
  function startPolling() {
    setInterval(() => {
      const hasGenerating = allArticles.some((a: any) => a.is_generating);
      // Polliamo solo se c'e' lavoro in corso: evita traffico superfluo.
      if (hasGenerating) {
        loadPendingArticles(true);
      }
    }, 10000);
  }

  // Event listeners
  document.getElementById('search')?.addEventListener('input', () => { currentPage = 1; renderPage(); });
  document.getElementById('category-filter')?.addEventListener('change', () => { currentPage = 1; renderPage(); });
  document.getElementById('prev-page')?.addEventListener('click', () => { if (currentPage > 1) { currentPage--; renderPage(); } });
  document.getElementById('next-page')?.addEventListener('click', () => { currentPage++; renderPage(); });

  checkAuth();
</script>
