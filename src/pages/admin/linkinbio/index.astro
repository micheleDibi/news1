---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<!-- Loading screen -->
<div id="loading-screen" class="fixed inset-0 bg-white z-50 flex items-center justify-center">
  <div class="text-center">
    <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600 mb-4"></div>
    <p class="text-gray-500 text-sm">Caricamento editor...</p>
  </div>
</div>

<div id="admin-content" class="hidden">
  <AdminLayout title="Link in Bio Editor">
    <div class="h-[calc(100vh-4rem)] flex flex-col">
      <!-- Top bar -->
      <div class="bg-white border-b border-gray-200 px-6 py-3 flex items-center justify-between flex-shrink-0">
        <div class="flex items-center gap-3">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </div>
            <div>
              <h1 class="text-lg font-semibold text-gray-900 leading-tight">Link in Bio</h1>
              <p class="text-xs text-gray-400">linkinbio.edunews24.it</p>
            </div>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <span id="item-count" class="text-xs text-gray-400 mr-2"></span>
          <a href="https://linkinbio.edunews24.it" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-600 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 hover:border-gray-300 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            Apri Sito
          </a>
        </div>
      </div>

      <!-- Main content: editor + preview -->
      <div class="flex-1 flex overflow-hidden">
        <!-- Left: Items editor -->
        <div class="flex-1 flex flex-col bg-gray-50 overflow-hidden">
          <!-- Add button with dropdown -->
          <div class="px-4 py-2.5 border-b border-gray-200 bg-white flex-shrink-0">
            <div class="relative" id="add-menu-wrapper">
              <button id="add-menu-trigger" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl border-2 border-dashed border-gray-300 text-gray-500 hover:border-indigo-400 hover:text-indigo-600 hover:bg-indigo-50/50 transition-all group">
                <svg class="w-5 h-5 transition-transform group-hover:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                <span class="text-sm font-medium">Aggiungi elemento</span>
              </button>
              <!-- Dropdown -->
              <div id="add-menu-dropdown" class="hidden absolute left-0 right-0 top-full mt-2 bg-white rounded-2xl shadow-xl border border-gray-200 z-30 p-3">
                <div class="grid grid-cols-2 gap-1.5">
                  <button class="add-type-btn flex items-center gap-3 px-3 py-2.5 rounded-xl text-left hover:bg-blue-50 transition-colors group" data-type="article">
                    <div class="w-9 h-9 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center flex-shrink-0 group-hover:bg-blue-200 transition-colors">
                      <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
                    </div>
                    <div><div class="text-sm font-medium text-gray-800">Articolo</div><div class="text-[11px] text-gray-400">Scegli dal sito</div></div>
                  </button>
                  <button class="add-type-btn flex items-center gap-3 px-3 py-2.5 rounded-xl text-left hover:bg-red-50 transition-colors group" data-type="breaking">
                    <div class="w-9 h-9 rounded-lg bg-red-100 text-red-600 flex items-center justify-center flex-shrink-0 group-hover:bg-red-200 transition-colors">
                      <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    </div>
                    <div><div class="text-sm font-medium text-gray-800">Ultima Ora</div><div class="text-[11px] text-gray-400">Ultimi articoli</div></div>
                  </button>
                  <button class="add-type-btn flex items-center gap-3 px-3 py-2.5 rounded-xl text-left hover:bg-orange-50 transition-colors group" data-type="category">
                    <div class="w-9 h-9 rounded-lg bg-orange-100 text-orange-600 flex items-center justify-center flex-shrink-0 group-hover:bg-orange-200 transition-colors">
                      <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                    </div>
                    <div><div class="text-sm font-medium text-gray-800">Categoria</div><div class="text-[11px] text-gray-400">Articoli per categoria</div></div>
                  </button>
                  <button class="add-type-btn flex items-center gap-3 px-3 py-2.5 rounded-xl text-left hover:bg-green-50 transition-colors group" data-type="link">
                    <div class="w-9 h-9 rounded-lg bg-green-100 text-green-600 flex items-center justify-center flex-shrink-0 group-hover:bg-green-200 transition-colors">
                      <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </div>
                    <div><div class="text-sm font-medium text-gray-800">Link esterno</div><div class="text-[11px] text-gray-400">URL personalizzato</div></div>
                  </button>
                  <button class="add-type-btn flex items-center gap-3 px-3 py-2.5 rounded-xl text-left hover:bg-purple-50 transition-colors group" data-type="social">
                    <div class="w-9 h-9 rounded-lg bg-purple-100 text-purple-600 flex items-center justify-center flex-shrink-0 group-hover:bg-purple-200 transition-colors">
                      <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
                    </div>
                    <div><div class="text-sm font-medium text-gray-800">Social</div><div class="text-[11px] text-gray-400">Facebook, IG, X...</div></div>
                  </button>
                  <button class="add-type-btn flex items-center gap-3 px-3 py-2.5 rounded-xl text-left hover:bg-gray-100 transition-colors group" data-type="header">
                    <div class="w-9 h-9 rounded-lg bg-gray-200 text-gray-600 flex items-center justify-center flex-shrink-0 group-hover:bg-gray-300 transition-colors">
                      <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h7"/></svg>
                    </div>
                    <div><div class="text-sm font-medium text-gray-800">Intestazione</div><div class="text-[11px] text-gray-400">Titolo sezione</div></div>
                  </button>
                  <button class="add-type-btn col-span-2 flex items-center gap-3 px-3 py-2.5 rounded-xl text-left hover:bg-yellow-50 transition-colors group" data-type="separator">
                    <div class="w-9 h-9 rounded-lg bg-yellow-100 text-yellow-600 flex items-center justify-center flex-shrink-0 group-hover:bg-yellow-200 transition-colors">
                      <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 12H4"/></svg>
                    </div>
                    <div><div class="text-sm font-medium text-gray-800">Separatore</div><div class="text-[11px] text-gray-400">Spazio tra elementi</div></div>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Items list -->
          <div class="flex-1 overflow-y-auto px-4 py-3" id="items-container">
            <div id="items-list" class="space-y-2">
              <div class="text-center py-12 text-gray-400 text-sm">Caricamento...</div>
            </div>
          </div>
        </div>

        <!-- Right: Live Preview -->
        <div class="w-[380px] flex-shrink-0 border-l border-gray-200 bg-gray-100 flex flex-col overflow-hidden hidden lg:flex">
          <div class="px-4 py-2.5 bg-white border-b border-gray-200 flex items-center justify-between flex-shrink-0">
            <span class="text-xs font-medium text-gray-500 uppercase tracking-wider">Anteprima</span>
            <div class="flex items-center gap-1.5">
              <div class="w-2 h-2 rounded-full bg-green-400"></div>
              <span class="text-xs text-gray-400">Live</span>
            </div>
          </div>
          <div class="flex-1 overflow-y-auto flex justify-center py-4">
            <div class="w-[320px]">
              <div class="bg-[#0a0f1a] rounded-[2rem] p-1 shadow-2xl">
                <div class="rounded-[1.75rem] overflow-hidden">
                  <div class="bg-[#0a0f1a] flex justify-center pt-2 pb-1">
                    <div class="w-20 h-5 bg-black rounded-full"></div>
                  </div>
                  <div id="preview-content" class="bg-[#0a0f1a] px-5 pb-6 min-h-[500px]" style="font-family: 'Inter', sans-serif;"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </AdminLayout>

  <!-- Slide-over panel for Add/Edit -->
  <div id="item-panel" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-gray-900/50 backdrop-blur-sm" id="panel-backdrop"></div>
    <div class="absolute inset-y-0 right-0 w-full max-w-lg bg-white shadow-2xl flex flex-col transform translate-x-full transition-transform duration-300 ease-out" id="panel-drawer">
      <!-- Panel header -->
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between flex-shrink-0">
        <h2 id="modal-title" class="text-lg font-semibold text-gray-900">Aggiungi Elemento</h2>
        <button id="cancel-btn" class="p-2 text-gray-400 hover:text-gray-600 rounded-lg hover:bg-gray-100 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Panel body -->
      <div class="flex-1 overflow-y-auto px-6 py-5">
        <form id="item-form">
          <input type="hidden" id="item-id">

          <!-- Type selector as cards -->
          <div class="mb-6" id="type-selector-section">
            <label class="block text-sm font-medium text-gray-700 mb-3">Tipo di elemento</label>
            <div class="grid grid-cols-4 gap-2" id="type-cards">
              <button type="button" class="type-card flex flex-col items-center gap-1 p-3 rounded-xl border-2 transition-all hover:shadow-sm" data-type="article">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
                <span class="text-[10px] font-medium">Articolo</span>
              </button>
              <button type="button" class="type-card flex flex-col items-center gap-1 p-3 rounded-xl border-2 transition-all hover:shadow-sm" data-type="link">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                <span class="text-[10px] font-medium">Link</span>
              </button>
              <button type="button" class="type-card flex flex-col items-center gap-1 p-3 rounded-xl border-2 transition-all hover:shadow-sm" data-type="social">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
                <span class="text-[10px] font-medium">Social</span>
              </button>
              <button type="button" class="type-card flex flex-col items-center gap-1 p-3 rounded-xl border-2 transition-all hover:shadow-sm" data-type="breaking">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                <span class="text-[10px] font-medium">Ultima Ora</span>
              </button>
              <button type="button" class="type-card flex flex-col items-center gap-1 p-3 rounded-xl border-2 transition-all hover:shadow-sm" data-type="category">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                <span class="text-[10px] font-medium">Categoria</span>
              </button>
              <button type="button" class="type-card flex flex-col items-center gap-1 p-3 rounded-xl border-2 transition-all hover:shadow-sm" data-type="header">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h7"/></svg>
                <span class="text-[10px] font-medium">Titolo</span>
              </button>
              <button type="button" class="type-card flex flex-col items-center gap-1 p-3 rounded-xl border-2 transition-all hover:shadow-sm" data-type="separator">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 12H4"/></svg>
                <span class="text-[10px] font-medium">Spazio</span>
              </button>
            </div>
          </div>
          <input type="hidden" id="item-type" value="article">

          <!-- Article section -->
          <div id="section-article" class="space-y-3">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Seleziona un articolo</label>
              <div id="selected-article" class="hidden mb-3 p-3 bg-indigo-50 border border-indigo-200 rounded-xl flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p id="selected-article-title" class="text-sm font-medium text-indigo-900 truncate"></p>
                  <p id="selected-article-category" class="text-xs text-indigo-600"></p>
                </div>
                <button type="button" id="clear-article" class="p-1 text-indigo-400 hover:text-indigo-600 rounded-lg hover:bg-indigo-100 transition-colors">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
              </div>
              <input type="hidden" id="item-article-id">
              <div class="flex gap-2">
                <div class="relative flex-1">
                  <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                  <input type="text" id="article-search" placeholder="Cerca per titolo..."
                    class="block w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 text-sm bg-gray-50 focus:bg-white transition-colors">
                </div>
                <select id="article-author-filter"
                  class="rounded-xl border border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 text-sm bg-gray-50 focus:bg-white transition-colors px-3 py-2.5">
                  <option value="">Tutti gli autori</option>
                </select>
              </div>
              <div id="article-results" class="mt-2 max-h-56 overflow-y-auto border border-gray-200 rounded-xl bg-white shadow-sm hidden"></div>
            </div>
          </div>

          <!-- Link section -->
          <div id="section-link" class="hidden space-y-4">
            <div>
              <label for="item-title" class="block text-sm font-medium text-gray-700 mb-1.5">Titolo</label>
              <input type="text" id="item-title" placeholder="Es: Visita il nostro blog"
                class="block w-full rounded-xl border border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 px-4 py-2.5 text-sm bg-gray-50 focus:bg-white transition-colors">
            </div>
            <div>
              <label for="item-url" class="block text-sm font-medium text-gray-700 mb-1.5">URL</label>
              <input type="url" id="item-url" placeholder="https://..."
                class="block w-full rounded-xl border border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 px-4 py-2.5 text-sm font-mono bg-gray-50 focus:bg-white transition-colors">
            </div>
          </div>

          <!-- Social section -->
          <div id="section-social" class="hidden space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Piattaforma</label>
              <div class="grid grid-cols-4 gap-2" id="social-icons-grid">
                <button type="button" class="social-icon-btn flex flex-col items-center gap-1 p-3 rounded-xl border-2 border-gray-200 hover:border-gray-300 transition-all" data-icon="facebook"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg><span class="text-[10px]">Facebook</span></button>
                <button type="button" class="social-icon-btn flex flex-col items-center gap-1 p-3 rounded-xl border-2 border-gray-200 hover:border-gray-300 transition-all" data-icon="instagram"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg><span class="text-[10px]">Instagram</span></button>
                <button type="button" class="social-icon-btn flex flex-col items-center gap-1 p-3 rounded-xl border-2 border-gray-200 hover:border-gray-300 transition-all" data-icon="twitter"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg><span class="text-[10px]">X</span></button>
