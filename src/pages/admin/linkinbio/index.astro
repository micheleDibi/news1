    globe: 'M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm6.918 6h-3.215a16.01 16.01 0 00-1.358-3.672A8.03 8.03 0 0118.918 8zM12 4.04c.94 1.058 1.68 2.298 2.166 3.66h-4.332A13.93 13.93 0 0112 4.04zM4.266 14A7.93 7.93 0 014 12c0-.69.098-1.36.266-2h3.73a16.47 16.47 0 000 4h-3.73zm.816 2h3.215a16.01 16.01 0 001.358 3.672A8.03 8.03 0 015.082 16zM8.297 8H5.082a8.03 8.03 0 013.563-3.672A16.01 16.01 0 008.297 8zm3.703 15.96a13.93 13.93 0 01-2.166-3.66h4.332A13.93 13.93 0 0112 19.96zM14.534 14H9.466a14.46 14.46 0 010-4h5.068a14.46 14.46 0 010 4zm.811 5.672A16.01 16.01 0 0016.703 16h3.215a8.03 8.03 0 01-3.563 3.672h-.01zM16.004 14a16.47 16.47 0 000-4h3.73c.168.64.266 1.31.266 2s-.098 1.36-.266 2h-3.73z',
  };

  let categoryColorMap: Record<string, string> = {};
  let allItems: any[] = [];
  let searchTimeout: ReturnType<typeof setTimeout> | null = null;
  let selectedArticleId: number | null = null;
  let currentType = 'article';
  let draggedIndex: number | null = null;
  const ARTICLES_PER_PAGE = 20;

  // DOM refs
  const $ = (id: string) => document.getElementById(id)!;
  const $i = (id: string) => document.getElementById(id) as HTMLInputElement;

  async function checkAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.href = '/login'; return; }
    const { data: profile } = await supabase.from('profiles').select('role, permissions').eq('id', session.user.id).single();
    if (!(profile?.role === 'admin' || !!profile?.permissions?.['manage_linkinbio'])) { window.location.href = '/admin'; return; }
    $('loading-screen').classList.add('hidden');
    $('admin-content').classList.remove('hidden');
    await loadCategories();
    initListeners();
    await loadItems();
  }

  let allCategories: { slug: string; name: string; color: string }[] = [];
  async function loadCategories() {
    const { data } = await supabase.from('categories').select('slug, name, color').order('name');
    if (data) {
      allCategories = data;
      for (const c of data) categoryColorMap[c.slug] = colorHexMap[c.color] || c.color || '#064C99';
      const select = $('item-category-select') as HTMLSelectElement;
      select.innerHTML = data.map(c => '<option value="' + c.slug + '">' + c.name + '</option>').join('');
    }
  }

  function getItemColor(item: any): string {
    if (item.type === 'article' && item.articles) return categoryColorMap[item.articles.category_slug] || '#064C99';
    return item.color || '#064C99';
  }

  function initListeners() {
    // Add menu dropdown
    const addTrigger = $('add-menu-trigger');
    const addDropdown = $('add-menu-dropdown');
    addTrigger.addEventListener('click', () => addDropdown.classList.toggle('hidden'));
    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest('#add-menu-wrapper')) addDropdown.classList.add('hidden');
    });

    // Add type buttons
    document.querySelectorAll('.add-type-btn').forEach(btn => {
      btn.addEventListener('click', () => { addDropdown.classList.add('hidden'); openPanel(btn.getAttribute('data-type')!); });
    });

    // Panel close
    const closePanel = () => closePanelFn();
    $('cancel-btn').addEventListener('click', closePanel);
    $('cancel-btn-footer').addEventListener('click', closePanel);
    $('panel-backdrop').addEventListener('click', closePanel);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePanel(); });

    // Type cards in panel
    document.querySelectorAll('.type-card').forEach(card => {
      card.addEventListener('click', () => {
        currentType = card.getAttribute('data-type')!;
        ($i('item-type')).value = currentType;
        updateTypeCards();
        updateFieldVisibility();
      });
    });

    // Social icon buttons
    document.querySelectorAll('.social-icon-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        ($i('item-icon')).value = btn.getAttribute('data-icon')!;
        document.querySelectorAll('.social-icon-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      });
    });

    // Color picker
    $i('item-color').addEventListener('input', () => { $('color-value').textContent = $i('item-color').value; });

    // Toggle switches
    setupToggle('item-new-tab');
    setupToggle('item-active');
    setupToggle('item-show-author');

    // Article search
    $i('article-search').addEventListener('input', () => {
      if (searchTimeout) clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => loadArticlesList($i('article-search').value), 300);
    });
    $i('article-search').addEventListener('focus', () => { if (!$i('article-search').value) loadArticlesList(); });

    // Author filter
    const authorFilter = $('article-author-filter') as HTMLSelectElement;
    authorFilter.addEventListener('change', () => loadArticlesList($i('article-search').value));
    loadAuthors();
    $('clear-article').addEventListener('click', () => {
      selectedArticleId = null;
      $i('item-article-id').value = '';
      $('selected-article').classList.add('hidden');
      $i('article-search').classList.remove('hidden');
      $i('article-search').value = '';
      loadArticlesList();
    });

    // Save
    $('save-btn').addEventListener('click', saveItem);
  }

  function setupToggle(id: string) {
    const checkbox = $i(id);
    const toggle = $(`${id}-toggle`);
    toggle.addEventListener('click', () => {
      checkbox.checked = !checkbox.checked;
      updateToggleUI(toggle, checkbox.checked);
    });
  }

  function updateToggleUI(toggle: HTMLElement, checked: boolean) {
    const dot = toggle.querySelector('span')!;
    if (checked) {
      toggle.classList.remove('bg-gray-300'); toggle.classList.add('bg-indigo-600');
      dot.classList.remove('translate-x-1'); dot.classList.add('translate-x-6');
    } else {
      toggle.classList.remove('bg-indigo-600'); toggle.classList.add('bg-gray-300');
      dot.classList.remove('translate-x-6'); dot.classList.add('translate-x-1');
    }
  }

  function updateTypeCards() {
    document.querySelectorAll('.type-card').forEach(c => {
      c.classList.toggle('active', c.getAttribute('data-type') === currentType);
    });
  }

  async function loadAuthors() {
    const { data } = await supabase.from('articles').select('creator').eq('isdraft', false);
    if (!data) return;
    const authors = [...new Set(data.map(a => a.creator).filter(Boolean))].sort();
    const select = $('article-author-filter') as HTMLSelectElement;
    select.innerHTML = '<option value="">Tutti gli autori</option>' + authors.map(a => `<option value="${a}">${a}</option>`).join('');
  }

  function updateFieldVisibility() {
    ['section-article', 'section-link', 'section-social', 'section-header', 'section-breaking', 'section-category'].forEach(s => $(s).classList.add('hidden'));
    if (currentType === 'article') $('section-article').classList.remove('hidden');
    if (currentType === 'link') $('section-link').classList.remove('hidden');
    if (currentType === 'social') $('section-social').classList.remove('hidden');
    if (currentType === 'header') $('section-header').classList.remove('hidden');
    if (currentType === 'breaking') $('section-breaking').classList.remove('hidden');
    if (currentType === 'category') $('section-category').classList.remove('hidden');
    $('color-field').classList.toggle('hidden', currentType !== 'link' && currentType !== 'header');
    $('show-author-field').classList.toggle('hidden', currentType !== 'article' && currentType !== 'breaking' && currentType !== 'category');
    $('new-tab-field').classList.toggle('hidden', currentType !== 'link' && currentType !== 'social');
    $('section-common').classList.toggle('hidden', currentType === 'separator');
  }

  function openPanel(type: string, item?: any) {
    currentType = type;
    $i('item-type').value = type;
    updateTypeCards();

    if (item) {
      $('modal-title').textContent = 'Modifica Elemento';
      $i('item-id').value = item.id;
      if (item.type === 'article' && item.articles) selectArticle(item.article_id, item.articles.title, item.articles.category);
      else { selectedArticleId = null; $i('item-article-id').value = ''; $('selected-article').classList.add('hidden'); $i('article-search').classList.remove('hidden'); }
      $i('item-title').value = item.title || '';
      $i('item-url').value = item.url || '';
      $i('item-icon').value = item.icon || 'facebook';
      $i('item-social-url').value = item.url || '';
      $i('item-header-title').value = item.title || '';
      $i('item-color').value = item.color || '#064C99';
      $('color-value').textContent = item.color || '#064C99';
      $i('item-new-tab').checked = item.open_in_new_tab;
      $i('item-active').checked = item.is_active;
      $i('item-show-author').checked = item.show_author !== false;
      $i('item-breaking-count').value = String(item.article_count || 15);
      $i('item-category-count').value = String(item.article_count || 3);
      if (item.category_slug) ($('item-category-select') as HTMLSelectElement).value = item.category_slug;
    } else {
      $('modal-title').textContent = 'Nuovo Elemento';
      $i('item-id').value = '';
      selectedArticleId = null; $i('item-article-id').value = ''; $('selected-article').classList.add('hidden');
      $i('article-search').classList.remove('hidden'); $i('article-search').value = '';
      $i('item-title').value = ''; $i('item-url').value = '';
      $i('item-icon').value = 'facebook'; $i('item-social-url').value = '';
      $i('item-header-title').value = '';
      $i('item-color').value = '#064C99'; $('color-value').textContent = '#064C99';
      $i('item-new-tab').checked = true; $i('item-active').checked = true;
      $i('item-show-author').checked = true;
      $i('item-breaking-count').value = '15';
      $i('item-category-count').value = '3';
      if (type === 'article') loadArticlesList();
    }

    // Update toggle UIs
    updateToggleUI($('item-new-tab-toggle'), $i('item-new-tab').checked);
    updateToggleUI($('item-active-toggle'), $i('item-active').checked);
    updateToggleUI($('item-show-author-toggle'), $i('item-show-author').checked);
    // Update social icon selection
    document.querySelectorAll('.social-icon-btn').forEach(b => b.classList.toggle('active', b.getAttribute('data-icon') === $i('item-icon').value));

    updateFieldVisibility();
    $('item-panel').classList.remove('hidden');
    requestAnimationFrame(() => {
      $('panel-drawer').classList.remove('translate-x-full');
    });
  }

  function closePanelFn() {
    $('panel-drawer').classList.add('translate-x-full');
    setTimeout(() => $('item-panel').classList.add('hidden'), 300);
    $('article-results').classList.add('hidden');
  }

  async function loadArticlesList(search = '') {
    const results = $('article-results');
    results.classList.remove('hidden');
    results.innerHTML = '<div class="p-4 text-sm text-gray-400 text-center">Caricamento...</div>';
    const authorFilter = ($('article-author-filter') as HTMLSelectElement).value;
    let query = supabase.from('articles').select('id, title, category, category_slug, published_at, creator').eq('isdraft', false).order('published_at', { ascending: false }).range(0, ARTICLES_PER_PAGE - 1);
    if (search) query = query.ilike('title', `%${search}%`);
    if (authorFilter) query = query.eq('creator', authorFilter);
    const { data: articles } = await query;
    if (!articles?.length) { results.innerHTML = '<div class="p-4 text-sm text-gray-400 text-center">Nessun articolo trovato</div>'; return; }
    results.innerHTML = articles.map(a => `
      <div class="article-option flex items-center gap-3 px-3 py-2.5 hover:bg-indigo-50 cursor-pointer border-b border-gray-50 last:border-0 transition-colors"
           data-id="${a.id}" data-title="${a.title.replace(/"/g, '&quot;')}" data-category="${a.category}">
        <div class="w-1.5 h-8 rounded-full flex-shrink-0" style="background: ${categoryColorMap[a.category_slug] || '#064C99'}"></div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-gray-900 truncate">${a.title}</p>
          <p class="text-xs text-gray-400 mt-0.5">${a.category} &middot; ${a.creator || ''} &middot; ${new Date(a.published_at).toLocaleDateString('it-IT')}</p>
        </div>
      </div>
    `).join('');
    results.querySelectorAll('.article-option').forEach(el => {
      el.addEventListener('click', () => selectArticle(parseInt(el.getAttribute('data-id')!), el.getAttribute('data-title')!, el.getAttribute('data-category')!));
    });
  }

  function selectArticle(id: number, title: string, category: string) {
    selectedArticleId = id;
    $i('item-article-id').value = String(id);
    $('selected-article-title').textContent = title;
    $('selected-article-category').textContent = category;
    $('selected-article').classList.remove('hidden');
    $i('article-search').classList.add('hidden');
    $('article-results').classList.add('hidden');
  }

  async function saveItem() {
    const type = currentType;
    const id = $i('item-id').value;
    const data: any = { type, is_active: $i('item-active').checked, description: null, show_author: $i('item-show-author').checked, updated_at: new Date().toISOString() };

    if (type === 'article') {
      if (!$i('item-article-id').value) { alert('Seleziona un articolo'); return; }
      Object.assign(data, { article_id: parseInt($i('item-article-id').value), title: null, url: null, icon: null, color: null, open_in_new_tab: true, show_author: $i('item-show-author').checked });
    } else if (type === 'link') {
      if (!$i('item-title').value || !$i('item-url').value) { alert('Inserisci titolo e URL'); return; }
      Object.assign(data, { article_id: null, title: $i('item-title').value, url: $i('item-url').value, icon: null, color: $i('item-color').value, open_in_new_tab: $i('item-new-tab').checked });
    } else if (type === 'social') {
      if (!$i('item-social-url').value) { alert('Inserisci URL del profilo'); return; }
      Object.assign(data, { article_id: null, title: null, url: $i('item-social-url').value, icon: $i('item-icon').value, color: null, open_in_new_tab: true });
    } else if (type === 'header') {
      if (!$i('item-header-title').value) { alert('Inserisci il titolo'); return; }
      Object.assign(data, { article_id: null, title: $i('item-header-title').value, url: null, icon: null, color: $i('item-color').value, open_in_new_tab: false });
    } else if (type === 'breaking') {
      const count = parseInt($i('item-breaking-count').value) || 15;
      Object.assign(data, { article_id: null, title: 'Ultima Ora', url: null, icon: null, color: '#cc0000', open_in_new_tab: true, article_count: count, category_slug: null });
    } else if (type === 'category') {
      const catSlug = ($('item-category-select') as HTMLSelectElement).value;
      if (!catSlug) { alert('Seleziona una categoria'); return; }
      const count = parseInt($i('item-category-count').value) || 3;
      const catName = allCategories.find(c => c.slug === catSlug)?.name || catSlug;
      Object.assign(data, { article_id: null, title: catName, url: null, icon: null, color: categoryColorMap[catSlug] || '#064C99', open_in_new_tab: true, article_count: count, category_slug: catSlug });
    } else if (type === 'separator') {
      Object.assign(data, { article_id: null, title: null, url: null, icon: null, color: null, open_in_new_tab: false, article_count: null, category_slug: null });
    }

    try {
      if (id) {
        const { error } = await supabase.from('linkinbio_items').update(data).eq('id', id);
        if (error) throw error;
      } else {
        data.position = allItems.length > 0 ? Math.max(...allItems.map(i => i.position)) + 1 : 0;
        const { error } = await supabase.from('linkinbio_items').insert([data]);
        if (error) throw error;
      }
      closePanelFn();
      await loadItems();
    } catch (e) { console.error(e); alert('Errore nel salvataggio'); }
  }

  async function loadItems() {
    const { data } = await supabase.from('linkinbio_items').select('*, articles(id, title, slug, category, category_slug, image_url, creator)').order('position', { ascending: true });
    allItems = data || [];
    renderItems();
    renderPreview();
    const active = allItems.filter(i => i.is_active).length;
    $('item-count').textContent = `${allItems.length} elementi (${active} attivi)`;
  }

  function renderItems() {
    const list = $('items-list');
    if (!allItems.length) {
      list.innerHTML = `
        <div class="text-center py-16">
          <div class="w-16 h-16 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          </div>
          <p class="text-gray-500 font-medium mb-1">Nessun elemento</p>
          <p class="text-gray-400 text-sm">Usa i pulsanti sopra per aggiungere contenuti</p>
        </div>`;
      return;
    }

    const typeIcons: Record<string, string> = {
      article: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>',
      link: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>',
      social: '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="' + socialIconPaths.globe + '"/></svg>',
      header: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/></svg>',
      separator: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/></svg>',
      breaking: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
      category: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>',
    };
    const typeColors: Record<string, string> = {
      article: 'bg-blue-50 text-blue-600', link: 'bg-green-50 text-green-600',
      social: 'bg-purple-50 text-purple-600', header: 'bg-gray-100 text-gray-600', separator: 'bg-yellow-50 text-yellow-600',
      breaking: 'bg-red-50 text-red-600', category: 'bg-orange-50 text-orange-600',
    };

    list.innerHTML = allItems.map((item, i) => {
      let title = '', sub = '';
      const color = getItemColor(item);
      if (item.type === 'article' && item.articles) { title = item.articles.title; sub = item.articles.category; }
      else if (item.type === 'link') { title = item.title || ''; sub = item.url || ''; }
      else if (item.type === 'social') { title = (item.icon || '').charAt(0).toUpperCase() + (item.icon || '').slice(1); sub = item.url || ''; }
      else if (item.type === 'header') { title = item.title || ''; sub = 'Intestazione'; }
      else if (item.type === 'separator') { title = 'Separatore'; }
      else if (item.type === 'breaking') { title = 'Ultima Ora'; sub = (item.article_count || 15) + ' articoli'; }
      else if (item.type === 'category') { title = item.title || item.category_slug || ''; sub = (item.article_count || 3) + ' articoli'; }

      const socialIcon = item.type === 'social' && item.icon ? `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="${socialIconPaths[item.icon] || socialIconPaths.globe}"/></svg>` : typeIcons[item.type] || '';

      return `
        <div class="item-card bg-white rounded-xl border border-gray-200 p-3 flex items-center gap-3 ${!item.is_active ? 'opacity-40' : ''}" data-index="${i}" draggable="true">
          <div class="flex flex-col gap-0.5 cursor-grab active:cursor-grabbing text-gray-300 hover:text-gray-400 flex-shrink-0" title="Trascina per riordinare">
            <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor"><circle cx="4" cy="3" r="1.5"/><circle cx="12" cy="3" r="1.5"/><circle cx="4" cy="8" r="1.5"/><circle cx="12" cy="8" r="1.5"/><circle cx="4" cy="13" r="1.5"/><circle cx="12" cy="13" r="1.5"/></svg>
          </div>
          <div class="w-1 h-10 rounded-full flex-shrink-0" style="background: ${color}"></div>
          <div class="w-8 h-8 rounded-lg ${typeColors[item.type] || 'bg-gray-100 text-gray-600'} flex items-center justify-center flex-shrink-0">
            ${socialIcon}
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 truncate">${title}</p>
            ${sub ? `<p class="text-xs text-gray-400 truncate">${sub}</p>` : ''}
          </div>
          <button class="toggle-active flex-shrink-0" data-id="${item.id}" data-active="${item.is_active}">
            <div class="relative inline-flex h-5 w-9 items-center rounded-full transition-colors ${item.is_active ? 'bg-indigo-600' : 'bg-gray-300'}">
              <span class="inline-block h-3.5 w-3.5 transform rounded-full bg-white transition-transform ${item.is_active ? 'translate-x-[18px]' : 'translate-x-[3px]'}"></span>
            </div>
          </button>
          <button class="edit-btn p-1.5 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors" data-index="${i}">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
          </button>
          <button class="delete-btn p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" data-id="${item.id}">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          </button>
        </div>`;
    }).join('');

    attachListListeners();
  }

  function attachListListeners() {
    document.querySelectorAll('.toggle-active').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id')!;
        const isActive = btn.getAttribute('data-active') === 'true';
        await supabase.from('linkinbio_items').update({ is_active: !isActive, updated_at: new Date().toISOString() }).eq('id', id);
        await loadItems();
      });
    });
    document.querySelectorAll('.edit-btn').forEach(btn => {
      btn.addEventListener('click', () => { const i = parseInt(btn.getAttribute('data-index')!); openPanel(allItems[i].type, allItems[i]); });
    });
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Eliminare questo elemento?')) return;
        await supabase.from('linkinbio_items').delete().eq('id', btn.getAttribute('data-id')!);
        await loadItems();
      });
    });

    // Drag and drop
    document.querySelectorAll('.item-card').forEach(card => {
      card.addEventListener('dragstart', (e) => {
        draggedIndex = parseInt((card as HTMLElement).dataset.index!);
        (card as HTMLElement).classList.add('dragging');
        (e as DragEvent).dataTransfer!.effectAllowed = 'move';
      });
      card.addEventListener('dragend', () => { (card as HTMLElement).classList.remove('dragging'); draggedIndex = null; document.querySelectorAll('.drag-over').forEach(c => c.classList.remove('drag-over')); });
      card.addEventListener('dragover', (e) => { e.preventDefault(); (e as DragEvent).dataTransfer!.dropEffect = 'move'; (card as HTMLElement).classList.add('drag-over'); });
      card.addEventListener('dragleave', () => (card as HTMLElement).classList.remove('drag-over'));
      card.addEventListener('drop', async (e) => {
        e.preventDefault();
        (card as HTMLElement).classList.remove('drag-over');
        const targetIndex = parseInt((card as HTMLElement).dataset.index!);
        if (draggedIndex === null || draggedIndex === targetIndex) return;
        await reorderItems(draggedIndex, targetIndex);
      });
    });
  }

  async function reorderItems(from: number, to: number) {
    const moved = allItems.splice(from, 1)[0];
    allItems.splice(to, 0, moved);
    const updates = allItems.map((item, i) => supabase.from('linkinbio_items').update({ position: i }).eq('id', item.id));
    await Promise.all(updates);
    await loadItems();
  }

  // Cache for dynamic articles (breaking/category)
  let previewDynArticles: Record<string, any[]> = {};

  async function fetchPreviewDynArticles() {
    const dynamicItems = allItems.filter(i => i.is_active && (i.type === 'breaking' || i.type === 'category'));
    for (const item of dynamicItems) {
      if (previewDynArticles[item.id]) continue;
      if (item.type === 'breaking') {
        const { data } = await supabase.from('articles').select('id, title, slug, category, category_slug, creator').eq('isdraft', false).order('published_at', { ascending: false }).limit(item.article_count || 15);
        previewDynArticles[item.id] = data || [];
      } else if (item.type === 'category' && item.category_slug) {
        const { data } = await supabase.from('articles').select('id, title, slug, category, category_slug, creator').eq('category_slug', item.category_slug).eq('isdraft', false).order('published_at', { ascending: false }).limit(item.article_count || 3);
        previewDynArticles[item.id] = data || [];
      }
    }
  }

  async function renderPreview() {
    const preview = document.getElementById('preview-content');
    if (!preview) return;
    // Fetch dynamic articles if needed
    previewDynArticles = {};
    await fetchPreviewDynArticles();

    const activeItems = allItems.filter(i => i.is_active);
    let html = '<div style="display:flex;flex-direction:column;align-items:center;gap:12px;padding-top:16px;">'
      + '<div style="color:rgba(255,255,255,0.5);font-size:10px;font-weight:500;letter-spacing:0.15em;text-transform:uppercase;">Notizie per il mondo della scuola</div>'
      + '<a style="display:flex;align-items:center;justify-content:center;gap:6px;width:100%;padding:10px;background:linear-gradient(135deg,#064C99,#0a6dd6);color:#fff;font-weight:700;font-size:12px;border-radius:10px;text-decoration:none;">Vai al sito <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg></a>';
    let inSocialGroup = false;

    function articleRow(title: string, color: string, authorName?: string, showAuthor?: boolean) {
      const auth = showAuthor && authorName ? '<span style="color:rgba(255,255,255,0.35);font-size:9px;">' + authorName + '</span>' : '';
      return '<a href="#" style="display:flex;align-items:center;width:100%;padding:8px 10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:10px;text-decoration:none;gap:8px;">'
        + '<div style="width:3px;height:24px;border-radius:2px;background:' + color + ';"></div>'
        + '<div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:1px;"><span style="color:rgba(255,255,255,0.9);font-size:11px;font-weight:500;line-height:1.3;">' + title + '</span>' + auth + '</div>'
        + '<svg width="10" height="10" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg></a>';
    }

    function sectionHeader(title: string, color: string) {
      return '<div style="width:100%;display:flex;align-items:center;gap:8px;margin-top:8px;"><div style="width:6px;height:6px;border-radius:50%;background:' + color + ';"></div><span style="font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:' + color + ';">' + title + '</span><div style="flex:1;height:1px;background:' + color + ';opacity:0.25;"></div></div>';
    }

    for (let i = 0; i < activeItems.length; i++) {
      const item = activeItems[i];
      const nextIsSocial = i + 1 < activeItems.length && activeItems[i + 1].type === 'social';
      if (item.type === 'social') {
        if (!inSocialGroup) { html += '<div style="display:flex;gap:8px;justify-content:center;margin-top:4px;">'; inSocialGroup = true; }
        const iconPath = socialIconPaths[item.icon || 'globe'] || socialIconPaths.globe;
        html += '<a href="#" style="width:32px;height:32px;display:flex;align-items:center;justify-content:center;border-radius:8px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.08);color:rgba(255,255,255,0.5);text-decoration:none;"><svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="' + iconPath + '"/></svg></a>';
        if (!nextIsSocial) { html += '</div>'; inSocialGroup = false; }
      } else if (item.type === 'header') {
        html += sectionHeader(item.title || '', item.color || '#064C99');
      } else if (item.type === 'separator') {
        html += '<div style="height:8px;"></div>';
      } else if (item.type === 'article' && item.articles) {
        html += articleRow(item.articles.title, getItemColor(item), item.articles.creator, item.show_author !== false);
      } else if (item.type === 'link') {
        html += articleRow(item.title || '', item.color || '#064C99');
      } else if (item.type === 'breaking' || item.type === 'category') {
        const c = item.color || '#064C99';
        html += sectionHeader(item.title || '', c);
        const dynArts = previewDynArticles[item.id] || [];
        const showAuth = item.show_author !== false;
        for (const a of dynArts) {
          const artColor = categoryColorMap[a.category_slug] || c;
          html += articleRow(a.title, artColor, a.creator, showAuth);
        }
      }
    }
    html += '<div style="margin-top:8px;color:rgba(255,255,255,0.2);font-size:9px;text-align:center;">&copy; ' + new Date().getFullYear() + ' EduNews24</div></div>';
    preview.innerHTML = html;
  }

  document.addEventListener('DOMContentLoaded', checkAuth);
</script>
