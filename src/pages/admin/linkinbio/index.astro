---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<!-- Loading screen -->
<div id="loading-screen" class="fixed inset-0 bg-white z-50 flex items-center justify-center">
  <div class="text-center">
    <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-sport-500 mb-4"></div>
    <p class="text-sport-600">Caricamento...</p>
  </div>
</div>

<div id="admin-content" class="hidden">
  <AdminLayout title="Gestione Link in Bio">
    <div class="py-6">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        <!-- Header -->
        <div class="md:flex md:items-center md:justify-between mb-6">
          <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
              Link in Bio
            </h2>
            <p class="mt-1 text-sm text-gray-500">Gestisci i contenuti della pagina linkinbio.edunews24.it</p>
          </div>
          <div class="mt-4 flex md:mt-0 md:ml-4 gap-2">
            <a
              href="https://linkinbio.edunews24.it"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50"
            >
              <svg class="-ml-1 mr-2 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              Anteprima
            </a>
            <button
              id="new-item-btn"
              class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
            >
              <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              Aggiungi Elemento
            </button>
          </div>
        </div>

        <!-- Items List -->
        <div class="bg-white shadow overflow-hidden sm:rounded-lg">
          <ul id="items-list" class="divide-y divide-gray-200">
            <li class="px-4 py-4 text-center text-gray-500">
              Caricamento...
            </li>
          </ul>
        </div>
      </div>
    </div>
  </AdminLayout>

  <!-- Modal Add/Edit -->
  <div id="item-modal" class="fixed inset-0 z-50 overflow-auto bg-gray-800 bg-opacity-50 hidden">
    <div class="relative p-4 bg-white w-full max-w-2xl m-auto rounded-lg shadow-lg mt-10 mb-10" id="modal-content">
      <h2 id="modal-title" class="text-xl font-semibold mb-4">Aggiungi Elemento</h2>
      <form id="item-form">
        <input type="hidden" id="item-id">

        <!-- Type selector -->
        <div class="mb-4">
          <label for="item-type" class="block text-sm font-medium text-gray-700">Tipo</label>
          <select id="item-type" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
            <option value="article">Articolo</option>
            <option value="link">Link Esterno</option>
            <option value="social">Social</option>
            <option value="header">Intestazione</option>
            <option value="separator">Separatore</option>
          </select>
        </div>

        <!-- Article section -->
        <div id="section-article" class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-2">Seleziona Articolo</label>
          <div id="selected-article" class="hidden mb-3 p-3 bg-indigo-50 border border-indigo-200 rounded-md flex items-center justify-between">
            <div>
              <span id="selected-article-title" class="text-sm font-medium text-indigo-800"></span>
              <span id="selected-article-category" class="ml-2 text-xs text-indigo-600"></span>
            </div>
            <button type="button" id="clear-article" class="text-indigo-400 hover:text-indigo-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          <input type="hidden" id="item-article-id">
          <input type="text" id="article-search" placeholder="Cerca articolo per titolo..."
            class="block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
          <div id="article-results" class="mt-2 max-h-60 overflow-y-auto border border-gray-200 rounded-md hidden">
          </div>
        </div>

        <!-- Link section -->
        <div id="section-link" class="hidden">
          <div class="mb-4">
            <label for="item-title" class="block text-sm font-medium text-gray-700">Titolo</label>
            <input type="text" id="item-title" placeholder="Titolo del link"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
          </div>
          <div class="mb-4">
            <label for="item-url" class="block text-sm font-medium text-gray-700">URL</label>
            <input type="url" id="item-url" placeholder="https://..."
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
          </div>
        </div>

        <!-- Social section -->
        <div id="section-social" class="hidden">
          <div class="mb-4">
            <label for="item-icon" class="block text-sm font-medium text-gray-700">Piattaforma</label>
            <select id="item-icon" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
              <option value="facebook">Facebook</option>
              <option value="instagram">Instagram</option>
              <option value="twitter">Twitter / X</option>
              <option value="youtube">YouTube</option>
              <option value="tiktok">TikTok</option>
              <option value="whatsapp">WhatsApp</option>
              <option value="telegram">Telegram</option>
              <option value="linkedin">LinkedIn</option>
            </select>
          </div>
          <div class="mb-4">
            <label for="item-social-url" class="block text-sm font-medium text-gray-700">URL Profilo</label>
            <input type="url" id="item-social-url" placeholder="https://..."
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
          </div>
        </div>

        <!-- Header section -->
        <div id="section-header" class="hidden">
          <div class="mb-4">
            <label for="item-header-title" class="block text-sm font-medium text-gray-700">Titolo Sezione</label>
            <input type="text" id="item-header-title" placeholder="Titolo intestazione"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
          </div>
        </div>

        <!-- Common fields -->
        <div id="section-common">
          <div class="mb-4" id="color-field">
            <label for="item-color" class="block text-sm font-medium text-gray-700">Colore</label>
            <div class="mt-1 flex items-center gap-2">
              <input type="color" id="item-color" value="#064C99"
                class="h-10 w-14 rounded border border-gray-300 cursor-pointer">
              <span id="color-value" class="text-sm text-gray-500">#064C99</span>
            </div>
          </div>

          <div class="mb-4" id="description-field">
            <label for="item-description" class="block text-sm font-medium text-gray-700">Descrizione (opzionale)</label>
            <textarea id="item-description" rows="2" placeholder="Breve descrizione..."
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"></textarea>
          </div>

          <div class="flex items-center gap-6 mb-4">
            <div class="flex items-center" id="new-tab-field">
              <input type="checkbox" id="item-new-tab" checked
                class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
              <label for="item-new-tab" class="ml-2 text-sm text-gray-700">Apri in nuova scheda</label>
            </div>
            <div class="flex items-center">
              <input type="checkbox" id="item-active" checked
                class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
              <label for="item-active" class="ml-2 text-sm text-gray-700">Attivo</label>
            </div>
          </div>
        </div>

        <!-- Buttons -->
        <div class="flex justify-end mt-6 gap-3">
          <button type="button" id="cancel-btn"
            class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md shadow-sm hover:bg-gray-50">
            Annulla
          </button>
          <button type="submit" id="save-btn"
            class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 border border-transparent rounded-md shadow-sm hover:bg-indigo-700">
            Salva
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  import { supabase } from '../../../lib/supabase';

  // State
  let allItems: any[] = [];
  let searchTimeout: ReturnType<typeof setTimeout> | null = null;
  let selectedArticleId: number | null = null;
  let articlePage = 0;
  const ARTICLES_PER_PAGE = 20;

  // DOM elements
  let modal: HTMLElement;
  let modalTitle: HTMLElement;
  let itemForm: HTMLFormElement;
  let itemIdInput: HTMLInputElement;
  let itemType: HTMLSelectElement;
  let itemArticleId: HTMLInputElement;
  let articleSearch: HTMLInputElement;
  let articleResults: HTMLElement;
  let selectedArticle: HTMLElement;
  let selectedArticleTitle: HTMLElement;
  let selectedArticleCategory: HTMLElement;
  let itemTitle: HTMLInputElement;
  let itemUrl: HTMLInputElement;
  let itemIcon: HTMLSelectElement;
  let itemSocialUrl: HTMLInputElement;
  let itemHeaderTitle: HTMLInputElement;
  let itemColor: HTMLInputElement;
  let colorValue: HTMLElement;
  let itemDescription: HTMLTextAreaElement;
  let itemNewTab: HTMLInputElement;
  let itemActive: HTMLInputElement;

  // Type badge config
  const typeBadges: Record<string, { label: string; bg: string; text: string }> = {
    article: { label: 'Articolo', bg: 'bg-blue-100', text: 'text-blue-800' },
    link: { label: 'Link', bg: 'bg-green-100', text: 'text-green-800' },
    social: { label: 'Social', bg: 'bg-purple-100', text: 'text-purple-800' },
    header: { label: 'Intestazione', bg: 'bg-gray-100', text: 'text-gray-800' },
    separator: { label: 'Separatore', bg: 'bg-yellow-100', text: 'text-yellow-800' },
  };

  async function checkAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.href = '/login'; return; }

    const { data: profile } = await supabase
      .from('profiles')
      .select('role, permissions')
      .eq('id', session.user.id)
      .single();

    const canManage = profile?.role === 'admin' || !!profile?.permissions?.['manage_linkinbio'];
    if (!canManage) { window.location.href = '/admin'; return; }

    document.getElementById('loading-screen')?.classList.add('hidden');
    document.getElementById('admin-content')?.classList.remove('hidden');

    initElements();
    initListeners();
    await loadItems();
  }

  function initElements() {
    modal = document.getElementById('item-modal')!;
    modalTitle = document.getElementById('modal-title')!;
    itemForm = document.getElementById('item-form') as HTMLFormElement;
    itemIdInput = document.getElementById('item-id') as HTMLInputElement;
    itemType = document.getElementById('item-type') as HTMLSelectElement;
    itemArticleId = document.getElementById('item-article-id') as HTMLInputElement;
    articleSearch = document.getElementById('article-search') as HTMLInputElement;
    articleResults = document.getElementById('article-results')!;
    selectedArticle = document.getElementById('selected-article')!;
    selectedArticleTitle = document.getElementById('selected-article-title')!;
    selectedArticleCategory = document.getElementById('selected-article-category')!;
    itemTitle = document.getElementById('item-title') as HTMLInputElement;
    itemUrl = document.getElementById('item-url') as HTMLInputElement;
    itemIcon = document.getElementById('item-icon') as HTMLSelectElement;
    itemSocialUrl = document.getElementById('item-social-url') as HTMLInputElement;
    itemHeaderTitle = document.getElementById('item-header-title') as HTMLInputElement;
    itemColor = document.getElementById('item-color') as HTMLInputElement;
    colorValue = document.getElementById('color-value')!;
    itemDescription = document.getElementById('item-description') as HTMLTextAreaElement;
    itemNewTab = document.getElementById('item-new-tab') as HTMLInputElement;
    itemActive = document.getElementById('item-active') as HTMLInputElement;
  }

  function initListeners() {
    document.getElementById('new-item-btn')!.addEventListener('click', () => openModal());
    document.getElementById('cancel-btn')!.addEventListener('click', () => closeModal());

    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal(); });

    itemType.addEventListener('change', () => updateFieldVisibility());
    itemColor.addEventListener('input', () => { colorValue.textContent = itemColor.value; });

    // Article search
    articleSearch.addEventListener('input', () => {
      if (searchTimeout) clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => searchArticles(articleSearch.value), 300);
    });
    articleSearch.addEventListener('focus', () => {
      if (!articleSearch.value) loadArticlesList();
    });

    document.getElementById('clear-article')!.addEventListener('click', () => {
      selectedArticleId = null;
      itemArticleId.value = '';
      selectedArticle.classList.add('hidden');
      articleSearch.classList.remove('hidden');
      articleResults.classList.remove('hidden');
      loadArticlesList();
    });

    // Form submit
    itemForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      await saveItem();
    });
  }

  function updateFieldVisibility() {
    const type = itemType.value;

    // Hide all type-specific sections
    document.getElementById('section-article')!.classList.add('hidden');
    document.getElementById('section-link')!.classList.add('hidden');
    document.getElementById('section-social')!.classList.add('hidden');
    document.getElementById('section-header')!.classList.add('hidden');

    // Show relevant section
    if (type === 'article') document.getElementById('section-article')!.classList.remove('hidden');
    if (type === 'link') document.getElementById('section-link')!.classList.remove('hidden');
    if (type === 'social') document.getElementById('section-social')!.classList.remove('hidden');
    if (type === 'header') document.getElementById('section-header')!.classList.remove('hidden');

    // Common fields visibility
    const showColor = type === 'link' || type === 'header';
    const showDescription = type !== 'separator';
    const showNewTab = type === 'link' || type === 'social';

    document.getElementById('color-field')!.classList.toggle('hidden', !showColor);
    document.getElementById('description-field')!.classList.toggle('hidden', !showDescription);
    document.getElementById('new-tab-field')!.classList.toggle('hidden', !showNewTab);
    document.getElementById('section-common')!.classList.toggle('hidden', type === 'separator');
  }

  async function loadArticlesList(search = '') {
    articleResults.classList.remove('hidden');
    articleResults.innerHTML = '<div class="p-3 text-sm text-gray-500 text-center">Caricamento...</div>';

    let query = supabase
      .from('articles')
      .select('id, title, category, category_slug, published_at')
      .eq('isdraft', false)
      .order('published_at', { ascending: false })
      .range(0, ARTICLES_PER_PAGE - 1);

    if (search) {
      query = query.ilike('title', `%${search}%`);
    }

    const { data: articles, error } = await query;

    if (error || !articles) {
      articleResults.innerHTML = '<div class="p-3 text-sm text-red-500">Errore nel caricamento</div>';
      return;
    }

    if (articles.length === 0) {
      articleResults.innerHTML = '<div class="p-3 text-sm text-gray-500 text-center">Nessun articolo trovato</div>';
      return;
    }

    articleResults.innerHTML = articles.map(a => `
      <div class="article-option px-3 py-2 hover:bg-indigo-50 cursor-pointer border-b border-gray-100 last:border-0"
           data-id="${a.id}" data-title="${a.title.replace(/"/g, '&quot;')}" data-category="${a.category}">
        <div class="text-sm font-medium text-gray-900 truncate">${a.title}</div>
        <div class="flex items-center gap-2 mt-0.5">
          <span class="text-xs text-indigo-600">${a.category}</span>
          <span class="text-xs text-gray-400">${new Date(a.published_at).toLocaleDateString('it-IT')}</span>
        </div>
      </div>
    `).join('');

    // Attach click handlers
    articleResults.querySelectorAll('.article-option').forEach(el => {
      el.addEventListener('click', () => {
        const id = parseInt(el.getAttribute('data-id')!);
        const title = el.getAttribute('data-title')!;
        const category = el.getAttribute('data-category')!;
        selectArticle(id, title, category);
      });
    });
  }

  function searchArticles(query: string) {
    loadArticlesList(query);
  }

  function selectArticle(id: number, title: string, category: string) {
    selectedArticleId = id;
    itemArticleId.value = String(id);
    selectedArticleTitle.textContent = title;
    selectedArticleCategory.textContent = category;
    selectedArticle.classList.remove('hidden');
    articleSearch.classList.add('hidden');
    articleResults.classList.add('hidden');
  }

  function openModal(item?: any) {
    if (item) {
      modalTitle.textContent = 'Modifica Elemento';
      itemIdInput.value = item.id;
      itemType.value = item.type;

      if (item.type === 'article' && item.articles) {
        selectArticle(item.article_id, item.articles.title, item.articles.category);
      } else {
        selectedArticleId = null;
        itemArticleId.value = '';
        selectedArticle.classList.add('hidden');
        articleSearch.classList.remove('hidden');
      }

      itemTitle.value = item.title || '';
      itemUrl.value = item.url || '';
      itemIcon.value = item.icon || 'facebook';
      itemSocialUrl.value = item.url || '';
      itemHeaderTitle.value = item.title || '';
      itemColor.value = item.color || '#064C99';
      colorValue.textContent = item.color || '#064C99';
      itemDescription.value = item.description || '';
      itemNewTab.checked = item.open_in_new_tab;
      itemActive.checked = item.is_active;
    } else {
      modalTitle.textContent = 'Aggiungi Elemento';
      itemIdInput.value = '';
      itemType.value = 'article';
      selectedArticleId = null;
      itemArticleId.value = '';
      selectedArticle.classList.add('hidden');
      articleSearch.classList.remove('hidden');
      articleSearch.value = '';
      itemTitle.value = '';
      itemUrl.value = '';
      itemIcon.value = 'facebook';
      itemSocialUrl.value = '';
      itemHeaderTitle.value = '';
      itemColor.value = '#064C99';
      colorValue.textContent = '#064C99';
      itemDescription.value = '';
      itemNewTab.checked = true;
      itemActive.checked = true;
      loadArticlesList();
    }

    updateFieldVisibility();
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    articleResults.classList.add('hidden');
  }

  async function saveItem() {
    const type = itemType.value;
    const id = itemIdInput.value;

    // Build data based on type
    const data: any = {
      type,
      is_active: itemActive.checked,
      description: itemDescription.value || null,
      updated_at: new Date().toISOString(),
    };

    if (type === 'article') {
      if (!itemArticleId.value) {
        alert('Seleziona un articolo');
        return;
      }
      data.article_id = parseInt(itemArticleId.value);
      data.title = null;
      data.url = null;
      data.icon = null;
      data.color = null;
      data.open_in_new_tab = true;
    } else if (type === 'link') {
      if (!itemTitle.value || !itemUrl.value) {
        alert('Inserisci titolo e URL');
        return;
      }
      data.article_id = null;
      data.title = itemTitle.value;
      data.url = itemUrl.value;
      data.icon = null;
      data.color = itemColor.value;
      data.open_in_new_tab = itemNewTab.checked;
    } else if (type === 'social') {
      if (!itemSocialUrl.value) {
        alert('Inserisci URL del profilo');
        return;
      }
      data.article_id = null;
      data.title = null;
      data.url = itemSocialUrl.value;
      data.icon = itemIcon.value;
      data.color = null;
      data.open_in_new_tab = true;
    } else if (type === 'header') {
      if (!itemHeaderTitle.value) {
        alert('Inserisci il titolo della sezione');
        return;
      }
      data.article_id = null;
      data.title = itemHeaderTitle.value;
      data.url = null;
      data.icon = null;
      data.color = itemColor.value;
      data.open_in_new_tab = false;
    } else if (type === 'separator') {
      data.article_id = null;
      data.title = null;
      data.url = null;
      data.icon = null;
      data.color = null;
      data.open_in_new_tab = false;
      data.description = null;
    }

    try {
      if (id) {
        const { error } = await supabase
          .from('linkinbio_items')
          .update(data)
          .eq('id', id);
        if (error) throw error;
      } else {
        // Set position to end
        const maxPos = allItems.length > 0 ? Math.max(...allItems.map(i => i.position)) + 1 : 0;
        data.position = maxPos;
        const { error } = await supabase
          .from('linkinbio_items')
          .insert([data]);
        if (error) throw error;
      }

      closeModal();
      await loadItems();
    } catch (error) {
      console.error('Error saving item:', error);
      alert('Errore nel salvataggio');
    }
  }

  async function loadItems() {
    const { data, error } = await supabase
      .from('linkinbio_items')
      .select('*, articles(id, title, slug, category, category_slug, image_url)')
      .order('position', { ascending: true });

    if (error) {
      console.error('Error loading items:', error);
      return;
    }

    allItems = data || [];
    renderItems();
  }

  function renderItems() {
    const list = document.getElementById('items-list')!;

    if (allItems.length === 0) {
      list.innerHTML = `
        <li class="px-4 py-8 text-center text-gray-500">
          <svg class="mx-auto h-12 w-12 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          <p>Nessun elemento. Clicca "Aggiungi Elemento" per iniziare.</p>
        </li>
      `;
      return;
    }

    list.innerHTML = allItems.map((item, index) => {
      const badge = typeBadges[item.type] || typeBadges.link;
      let title = '';
      let subtitle = '';

      if (item.type === 'article' && item.articles) {
        title = item.articles.title;
        subtitle = item.articles.category;
      } else if (item.type === 'link') {
        title = item.title || '';
        subtitle = item.url || '';
      } else if (item.type === 'social') {
        title = (item.icon || 'social').charAt(0).toUpperCase() + (item.icon || 'social').slice(1);
        subtitle = item.url || '';
      } else if (item.type === 'header') {
        title = item.title || '';
        subtitle = 'Intestazione sezione';
      } else if (item.type === 'separator') {
        title = 'Separatore';
        subtitle = '';
      }

      return `
        <li class="flex items-center gap-3 py-3 px-4 ${!item.is_active ? 'opacity-50' : ''}">
          <!-- Reorder buttons -->
          <div class="flex flex-col gap-0.5">
            <button class="move-up p-0.5 text-gray-400 hover:text-gray-600 ${index === 0 ? 'invisible' : ''}" data-id="${item.id}" data-pos="${item.position}" title="Sposta su">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg>
            </button>
            <button class="move-down p-0.5 text-gray-400 hover:text-gray-600 ${index === allItems.length - 1 ? 'invisible' : ''}" data-id="${item.id}" data-pos="${item.position}" title="Sposta giu">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
          </div>

          <!-- Color indicator -->
          ${item.color ? `<div class="w-1 h-8 rounded-full flex-shrink-0" style="background: ${item.color}"></div>` : ''}

          <!-- Content -->
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${badge.bg} ${badge.text}">${badge.label}</span>
              <span class="text-sm font-medium text-gray-900 truncate">${title}</span>
            </div>
            ${subtitle ? `<p class="text-xs text-gray-500 truncate mt-0.5">${subtitle}</p>` : ''}
          </div>

          <!-- Toggle active -->
          <button class="toggle-active flex-shrink-0" data-id="${item.id}" data-active="${item.is_active}" title="${item.is_active ? 'Disattiva' : 'Attiva'}">
            <div class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${item.is_active ? 'bg-indigo-600' : 'bg-gray-300'}">
              <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform ${item.is_active ? 'translate-x-6' : 'translate-x-1'}"></span>
            </div>
          </button>

          <!-- Actions -->
          <div class="flex items-center gap-2 flex-shrink-0">
            <button class="edit-btn text-indigo-600 hover:text-indigo-900" data-index="${index}" title="Modifica">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </button>
            <button class="delete-btn text-red-600 hover:text-red-900" data-id="${item.id}" title="Elimina">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
          </div>
        </li>
      `;
    }).join('');

    attachListListeners();
  }

  function attachListListeners() {
    // Move up
    document.querySelectorAll('.move-up').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id')!;
        const index = allItems.findIndex(i => i.id === id);
        if (index <= 0) return;
        await swapPositions(index, index - 1);
      });
    });

    // Move down
    document.querySelectorAll('.move-down').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id')!;
        const index = allItems.findIndex(i => i.id === id);
        if (index < 0 || index >= allItems.length - 1) return;
        await swapPositions(index, index + 1);
      });
    });

    // Toggle active
    document.querySelectorAll('.toggle-active').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id')!;
        const isActive = btn.getAttribute('data-active') === 'true';
        await supabase
          .from('linkinbio_items')
          .update({ is_active: !isActive, updated_at: new Date().toISOString() })
          .eq('id', id);
        await loadItems();
      });
    });

    // Edit
    document.querySelectorAll('.edit-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const index = parseInt(btn.getAttribute('data-index')!);
        openModal(allItems[index]);
      });
    });

    // Delete
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id')!;
        if (!confirm('Sei sicuro di voler eliminare questo elemento?')) return;
        await supabase.from('linkinbio_items').delete().eq('id', id);
        await loadItems();
      });
    });
  }

  async function swapPositions(indexA: number, indexB: number) {
    const itemA = allItems[indexA];
    const itemB = allItems[indexB];
    const posA = itemA.position;
    const posB = itemB.position;

    await Promise.all([
      supabase.from('linkinbio_items').update({ position: posB }).eq('id', itemA.id),
      supabase.from('linkinbio_items').update({ position: posA }).eq('id', itemB.id),
    ]);

    await loadItems();
  }

  document.addEventListener('DOMContentLoaded', () => {
    checkAuth();
  });
</script>
