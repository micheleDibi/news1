---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, proxy-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');
Astro.response.headers.set('Expires', '0');
Astro.response.headers.set('Surrogate-Control', 'no-store');
---

<div id="loading-screen" class="fixed inset-0 bg-white z-50 flex items-center justify-center">
  <div class="text-center">
    <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-sport-500 mb-4"></div>
    <p class="text-sport-600">Caricamento...</p>
  </div>
</div>

<div id="admin-content" class="hidden">
  <AdminLayout title="Log Pipeline">
    <div class="py-6">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        <div class="mb-6">
          <h2 class="text-2xl font-bold text-gray-900">Log Pipeline</h2>
          <p class="mt-1 text-sm text-gray-500">Visualizza i log del backend e del frontend in tempo reale.</p>
        </div>

        <!-- Filters -->
        <div class="bg-white shadow rounded-lg mb-6">
          <div class="p-4">
            <div class="flex flex-wrap items-center gap-3">
              <!-- Date -->
              <div class="relative inline-flex items-center">
                <svg class="absolute left-2.5 h-3.5 w-3.5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <input type="date" id="date-filter" class="pl-8 pr-3 py-1.5 text-sm border border-gray-300 rounded-full bg-white hover:bg-gray-50 focus:ring-2 focus:ring-primary focus:border-primary transition-colors cursor-pointer" />
              </div>

              <!-- Source -->
              <div class="relative inline-flex items-center">
                <svg class="absolute left-2.5 h-3.5 w-3.5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />
                </svg>
                <select id="source-filter" class="pl-8 pr-8 py-1.5 text-sm border border-gray-300 rounded-full bg-white hover:bg-gray-50 focus:ring-2 focus:ring-primary focus:border-primary transition-colors appearance-none cursor-pointer">
                  <option value="">Tutte le sorgenti</option>
                  <option value="backend">Backend</option>
                  <option value="frontend">Frontend</option>
                </select>
              </div>

              <!-- Level -->
              <div class="relative inline-flex items-center">
                <svg class="absolute left-2.5 h-3.5 w-3.5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12" />
                </svg>
                <select id="level-filter" class="pl-8 pr-8 py-1.5 text-sm border border-gray-300 rounded-full bg-white hover:bg-gray-50 focus:ring-2 focus:ring-primary focus:border-primary transition-colors appearance-none cursor-pointer">
                  <option value="">Tutti i livelli</option>
                  <option value="DEBUG">DEBUG</option>
                  <option value="INFO">INFO</option>
                  <option value="WARNING">WARNING</option>
                  <option value="ERROR">ERROR</option>
                </select>
              </div>

              <!-- Limit -->
              <div class="relative inline-flex items-center">
                <select id="limit-filter" class="pl-3 pr-8 py-1.5 text-sm border border-gray-300 rounded-full bg-white hover:bg-gray-50 focus:ring-2 focus:ring-primary focus:border-primary transition-colors appearance-none cursor-pointer">
                  <option value="100">100 righe</option>
                  <option value="250">250 righe</option>
                  <option value="500">500 righe</option>
                  <option value="1000">1000 righe</option>
                </select>
              </div>

              <!-- Search -->
              <div class="flex-1 min-w-[200px] relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input type="text" id="search-filter" placeholder="Filtra nei log..." class="w-full pl-9 pr-3 py-1.5 text-sm border border-gray-300 rounded-full bg-white hover:bg-gray-50 focus:ring-2 focus:ring-primary focus:border-primary transition-colors" />
              </div>

              <!-- Actions -->
              <button id="refresh-btn" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-primary hover:bg-sport-700 rounded-full transition-colors shadow-sm">
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Aggiorna
              </button>
            </div>
          </div>
        </div>

        <!-- Stats -->
        <div class="mb-4 flex items-center justify-between">
          <p id="results-info" class="text-sm text-gray-500"></p>
          <div id="loading-indicator" class="hidden items-center gap-2 text-sm text-blue-600">
            <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
            Caricamento...
          </div>
        </div>

        <!-- Log entries -->
        <div id="log-container" class="bg-gray-900 rounded-xl shadow-lg overflow-hidden font-mono text-sm">
          <div class="overflow-x-auto max-h-[70vh] overflow-y-auto" id="log-scroll">
            <table class="w-full">
              <thead class="bg-gray-800 sticky top-0 z-10">
                <tr>
                  <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider w-[180px]">Timestamp</th>
                  <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider w-[70px]">Livello</th>
                  <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider w-[200px]">Sorgente</th>
                  <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Messaggio</th>
                </tr>
              </thead>
              <tbody id="log-body" class="divide-y divide-gray-800/50">
                <tr>
                  <td colspan="4" class="px-4 py-10 text-center text-gray-500">Caricamento log...</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Empty state -->
        <div id="empty-state" class="hidden text-center py-16 bg-white rounded-xl shadow-sm mt-6">
          <svg class="mx-auto w-16 h-16 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <p class="text-gray-500 text-lg font-medium">Nessun log trovato</p>
          <p class="text-gray-400 text-sm mt-1">Prova a cambiare la data o i filtri</p>
        </div>
      </div>
    </div>
  </AdminLayout>
</div>

<script>
  import { supabase } from '../../../lib/supabase';

  const levelColors: Record<string, string> = {
    'DEBUG': 'text-gray-400',
    'INFO': 'text-green-400',
    'WARNING': 'text-yellow-400',
    'ERROR': 'text-red-400',
  };

  const levelBg: Record<string, string> = {
    'DEBUG': '',
    'INFO': '',
    'WARNING': 'bg-yellow-900/10',
    'ERROR': 'bg-red-900/20',
  };

  async function checkAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.href = '/login'; return; }
    const { data: profile, error } = await supabase
      .from('profiles').select('role').eq('id', session.user.id).single();
    if (error || profile?.role !== 'admin') { window.location.href = '/login'; return; }
    document.getElementById('loading-screen')?.classList.add('hidden');
    document.getElementById('admin-content')?.classList.remove('hidden');
    // Set today's date as default
    const today = new Date().toISOString().split('T')[0];
    (document.getElementById('date-filter') as HTMLInputElement).value = today;
    loadLogs();
  }

  async function loadLogs() {
    const loadingIndicator = document.getElementById('loading-indicator');
    if (loadingIndicator) { loadingIndicator.classList.remove('hidden'); loadingIndicator.classList.add('flex'); }

    const date = (document.getElementById('date-filter') as HTMLInputElement)?.value || '';
    const source = (document.getElementById('source-filter') as HTMLSelectElement)?.value || '';
    const level = (document.getElementById('level-filter') as HTMLSelectElement)?.value || '';
    const limit = (document.getElementById('limit-filter') as HTMLSelectElement)?.value || '100';
    const search = (document.getElementById('search-filter') as HTMLInputElement)?.value?.toLowerCase() || '';

    const params = new URLSearchParams();
    if (date) params.set('date', date);
    if (source) params.set('source', source);
    if (level) params.set('level', level);
    params.set('limit', limit);

    try {
      const res = await fetch(`/api/logs?${params}`);
      if (!res.ok) throw new Error('Failed to fetch logs');
      const data = await res.json();

      let logs = data.logs || [];

      // Client-side search filter
      if (search) {
        logs = logs.filter((entry: any) =>
          entry.message?.toLowerCase().includes(search) ||
          entry.source?.toLowerCase().includes(search)
        );
      }

      const body = document.getElementById('log-body');
      const emptyState = document.getElementById('empty-state');
      const logContainer = document.getElementById('log-container');
      const resultsInfo = document.getElementById('results-info');

      if (resultsInfo) {
        resultsInfo.innerHTML = `<span class="font-semibold text-gray-700">${logs.length}</span> righe${data.total > logs.length ? ` di ${data.total} totali` : ''}`;
      }

      if (logs.length === 0) {
        if (emptyState) emptyState.classList.remove('hidden');
        if (logContainer) logContainer.classList.add('hidden');
        return;
      }

      if (emptyState) emptyState.classList.add('hidden');
      if (logContainer) logContainer.classList.remove('hidden');

      if (body) {
        body.innerHTML = logs.map((entry: any) => {
          const color = levelColors[entry.level] || 'text-gray-300';
          const bg = levelBg[entry.level] || '';
          const sourceShort = entry.source?.replace('backend:', '').replace('frontend:', '') || '';
          const sourceType = entry.source?.startsWith('backend') ? 'BE' : 'FE';
          const sourceColor = sourceType === 'BE' ? 'text-blue-400' : 'text-purple-400';

          return `<tr class="${bg} hover:bg-gray-800/50">
            <td class="px-4 py-1.5 text-gray-500 whitespace-nowrap">${entry.timestamp || ''}</td>
            <td class="px-3 py-1.5 whitespace-nowrap"><span class="${color} font-semibold">${entry.level || ''}</span></td>
            <td class="px-3 py-1.5 whitespace-nowrap text-xs"><span class="${sourceColor}">[${sourceType}]</span> <span class="text-gray-500">${sourceShort}</span></td>
            <td class="px-4 py-1.5 text-gray-300 break-all">${escapeHtml(entry.message || '')}</td>
          </tr>`;
        }).join('');
      }
    } catch (err) {
      console.error('Error loading logs:', err);
      const body = document.getElementById('log-body');
      if (body) {
        body.innerHTML = '<tr><td colspan="4" class="px-4 py-10 text-center text-red-400">Errore nel caricamento dei log</td></tr>';
      }
    } finally {
      if (loadingIndicator) { loadingIndicator.classList.add('hidden'); loadingIndicator.classList.remove('flex'); }
    }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Event listeners
  document.getElementById('date-filter')?.addEventListener('change', loadLogs);
  document.getElementById('source-filter')?.addEventListener('change', loadLogs);
  document.getElementById('level-filter')?.addEventListener('change', loadLogs);
  document.getElementById('limit-filter')?.addEventListener('change', loadLogs);
  document.getElementById('refresh-btn')?.addEventListener('click', loadLogs);

  let searchTimeout: number;
  document.getElementById('search-filter')?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(loadLogs, 300) as unknown as number;
  });

  checkAuth();
</script>
